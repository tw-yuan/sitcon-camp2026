---
import X from "~icons/lucide/x";
import type { ScheduleBlock, ScheduleDay, ScheduleDayType, ScheduleEvent, ScheduleEventCategory } from "@/data/schedule";
import { scheduleDays, scheduleEvents, scheduleMeta, scheduleSlots } from "@/data/schedule";

const eventsById = new Map(scheduleEvents.map(event => [event.id, event]));
const scheduleSlotIndexMap = new Map(scheduleSlots.map((slot, index) => [slot, index]));
const interactiveScheduleEvents = scheduleEvents.filter(event => event.isInteractive === true && event.description && event.image);

const dayAccentClassMap: Record<ScheduleDayType, string> = {
	opening: "schedule-day--sky",
	software: "schedule-day--green",
	"artificial-intelligence": "schedule-day--orange",
	security: "schedule-day--blue",
	closing: "schedule-day--dark"
};

const categoryClassMap: Record<ScheduleEventCategory, string> = {
	啟程: "schedule-badge--green",
	主線課程: "schedule-badge--blue",
	社群活動: "schedule-badge--orange",
	生活: "schedule-badge--sky",
	休息: "schedule-badge--lavender",
	總結: "schedule-badge--dark"
};

const blockCategoryClassMap: Record<ScheduleEventCategory, string> = {
	啟程: "schedule-event--green",
	主線課程: "schedule-event--blue",
	社群活動: "schedule-event--orange",
	生活: "schedule-event--cream",
	休息: "schedule-event--lavender",
	總結: "schedule-event--dark"
};

const getEvent = (eventId: string): ScheduleEvent => {
	const event = eventsById.get(eventId);

	if (!event) {
		throw new Error(`Missing schedule event: ${eventId}`);
	}

	return event;
};

const getBlockSpan = (block: ScheduleBlock): number => {
	const startIndex = scheduleSlotIndexMap.get(block.startSlot);

	if (startIndex === undefined) {
		throw new Error(`Invalid schedule slot: ${block.startSlot}`);
	}

	const remainingPeriods = scheduleSlots.length - startIndex;
	return Math.max(1, Math.min(block.span ?? 1, remainingPeriods));
};

const getBlockRangeLabel = (block: ScheduleBlock): string => {
	const startIndex = scheduleSlotIndexMap.get(block.startSlot);

	if (startIndex === undefined) {
		throw new Error(`Invalid schedule slot: ${block.startSlot}`);
	}

	const span = getBlockSpan(block);
	const endSlot = scheduleSlots[startIndex + span - 1];

	return block.startSlot === endSlot ? block.startSlot : `${block.startSlot} - ${endSlot}`;
};

const getRenderableBlocks = (day: ScheduleDay) => {
	const occupiedSlots = Array.from({ length: scheduleSlots.length }, () => false);
	const blocks = day.blocks.map(block => {
		const startIndex = scheduleSlotIndexMap.get(block.startSlot);

		if (startIndex === undefined) {
			throw new Error(`Invalid schedule slot: ${block.startSlot}`);
		}

		const span = getBlockSpan(block);

		for (let offset = 0; offset < span; offset += 1) {
			const slotIndex = startIndex + offset;

			if (occupiedSlots[slotIndex]) {
				throw new Error(`Overlapping schedule blocks in day: ${day.id}`);
			}

			occupiedSlots[slotIndex] = true;
		}

		const event = getEvent(block.eventId);

		return {
			...block,
			event,
			isInteractive: event.isInteractive === true && Boolean(event.description && event.image),
			label: getBlockRangeLabel(block),
			rowStart: startIndex + 2,
			span
		};
	});

	const emptyBlocks = scheduleSlots.flatMap((slot, index) =>
		occupiedSlots[index]
			? []
			: [
					{
						startSlot: slot,
						span: 1,
						eventId: "",
						event: null,
						isInteractive: false,
						label: slot,
						rowStart: index + 2
					}
				]
	);

	return [...blocks, ...emptyBlocks].sort((left, right) => left.rowStart - right.rowStart);
};
---

<section class="schedule-page" aria-labelledby="schedule-title">
	<div class="schedule-page__content" data-schedule-page-content>
		<div class="site-container">
			<header class="schedule-hero">
				<p class="schedule-hero__eyebrow">SITCON Camp 2026</p>
				<h1 id="schedule-title" class="schedule-hero__title">{scheduleMeta.title}</h1>
				<p class="schedule-hero__lead">{scheduleMeta.description}</p>
			</header>

			{
				scheduleMeta.note && (
					<div class="schedule-notes" aria-label="課表公告">
						<p class="schedule-note">{scheduleMeta.note}</p>
					</div>
				)
			}

			<div class="schedule-board schedule-board--scroll" aria-label="五天活動日程輪廓">
				<div class="schedule-time-rail" aria-hidden="true">
					<div class="schedule-time-rail__spacer"></div>
					{scheduleSlots.map(slot => <div class="schedule-time-rail__period">{slot}</div>)}
				</div>

				<div class="schedule-days-track" data-schedule-days-track>
					{
						scheduleDays.map(day => (
							<article class:list={["schedule-day", dayAccentClassMap[day.type]]}>
								<header class="schedule-day__header">
									<div class="schedule-day__header-copy">
										<h2 class="schedule-day__title">{day.title}</h2>
										<p class="schedule-day__subtitle">{day.subtitle}</p>
									</div>
								</header>

								<div class="schedule-day__blocks">
									{getRenderableBlocks(day).map(block => {
										const event = block.event;
										const isInteractive = block.isInteractive;

										return (
											<section
												class:list={[
													"schedule-block",
													{
														"schedule-block--empty": event === null,
														"schedule-block--spanning": block.span > 1
													}
												]}
												style={`--schedule-block-row:${block.rowStart}; --schedule-block-span:${block.span};`}
												aria-label={`${day.title}${block.label}活動`}
											>
												<h3 class="schedule-block__period">{block.label}</h3>
												{event ? (
													<div class="schedule-block__events">
														{isInteractive ? (
															<button
																type="button"
																class:list={["schedule-event", blockCategoryClassMap[event.category], { "schedule-event--spanning": block.span > 1 }]}
																data-schedule-event-trigger={event.id}
																aria-label={`查看${event.name}介紹`}
															>
																<div class="schedule-event__body">
																	<div class="schedule-event__content">
																		<span class:list={["schedule-event__badge", categoryClassMap[event.category]]}>{event.category}</span>
																		<span class="schedule-event__name">{event.name}</span>
																	</div>
																</div>
															</button>
														) : (
															<div class:list={["schedule-event", "schedule-event--static", blockCategoryClassMap[event.category], { "schedule-event--spanning": block.span > 1 }]}>
																<div class="schedule-event__body">
																	<div class="schedule-event__content">
																		<span class:list={["schedule-event__badge", categoryClassMap[event.category]]}>{event.category}</span>
																		<span class="schedule-event__name">{event.name}</span>
																	</div>
																</div>
															</div>
														)}
													</div>
												) : (
													<p class="schedule-block__empty-text"> </p>
												)}
											</section>
										);
									})}
								</div>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</div>

	{
		interactiveScheduleEvents.map(event => (
			<div class="schedule-dialog" data-schedule-dialog={event.id} role="dialog" aria-modal="true" aria-labelledby={`schedule-dialog-title-${event.id}`} hidden>
				<div class="schedule-dialog__panel">
					<div class="schedule-dialog__image-wrap">
						<img class="schedule-dialog__image" src={event.image?.src} alt={event.image?.alt} loading="lazy" decoding="async" />
					</div>
					<div class="schedule-dialog__content">
						<span class:list={["schedule-dialog__badge", categoryClassMap[event.category]]}>{event.category}</span>
						<h2 id={`schedule-dialog-title-${event.id}`} class="schedule-dialog__title" tabindex="-1">
							{event.name}
						</h2>
						<p class="schedule-dialog__description">{event.description}</p>
					</div>
					<button type="button" class="schedule-dialog__close" data-schedule-dialog-close aria-label={`關閉${event.name}介紹`}>
						<X width={24} height={24} stroke-width={3} />
					</button>
				</div>
			</div>
		))
	}
</section>

<script>
	document.addEventListener("astro:page-load", () => {
		const ac = new AbortController();
		const { signal } = ac;
		document.addEventListener(
			"astro:before-swap",
			() => {
				closeDialog();
				ac.abort();
			},
			{ once: true }
		);

		const dialogs = new Map(Array.from(document.querySelectorAll<HTMLElement>("[data-schedule-dialog]")).map(dialog => [dialog.dataset.scheduleDialog ?? "", dialog]));
		const pageContent = document.querySelector<HTMLElement>("[data-schedule-page-content]");
		let activeDialog: HTMLElement | null = null;
		let lastFocusedElement: HTMLElement | null = null;
		let scrollPosition = 0;
		const focusableSelector = [
			"a[href]",
			"button:not([disabled])",
			'input:not([disabled]):not([type="hidden"])',
			"select:not([disabled])",
			"textarea:not([disabled])",
			'[tabindex]:not([tabindex="-1"])'
		].join(",");

		const getFocusableElements = (dialog: HTMLElement) => Array.from(dialog.querySelectorAll<HTMLElement>(focusableSelector)).filter(element => !element.closest("[hidden]"));

		const setPageContentInert = (isInert: boolean) => {
			if (!pageContent) return;

			const pageContentWithInert = pageContent as HTMLElement & { inert?: boolean };
			if ("inert" in pageContentWithInert) {
				pageContentWithInert.inert = isInert;
			}
			pageContent.toggleAttribute("inert", isInert);
			if (isInert) {
				pageContent.setAttribute("aria-hidden", "true");
			} else {
				pageContent.removeAttribute("aria-hidden");
			}
		};

		const focusDialogTitle = (dialog: HTMLElement) => {
			dialog.querySelector<HTMLElement>(`[id="schedule-dialog-title-${dialog.dataset.scheduleDialog ?? ""}"]`)?.focus({ preventScroll: true });
		};

		const restoreFocus = (dialog: HTMLElement | null) => {
			const fallbackTrigger = dialog?.dataset.scheduleDialog ? document.querySelector<HTMLElement>(`[data-schedule-event-trigger="${dialog.dataset.scheduleDialog}"]`) : null;
			const target = lastFocusedElement && lastFocusedElement.isConnected && (!dialog || !dialog.contains(lastFocusedElement)) ? lastFocusedElement : fallbackTrigger;

			target?.focus({ preventScroll: true });
			lastFocusedElement = null;
		};

		const closeDialog = (dialog = activeDialog) => {
			if (!dialog) return;

			dialog.hidden = true;
			setPageContentInert(false);
			activeDialog = null;
			document.documentElement.classList.remove("schedule-dialog-is-open");
			window.scrollTo({ top: scrollPosition, left: 0, behavior: "instant" });
			restoreFocus(dialog);
		};

		const openDialog = (dialog: HTMLElement) => {
			if (activeDialog && activeDialog !== dialog) {
				closeDialog(activeDialog);
			}

			lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
			scrollPosition = window.scrollY;
			setPageContentInert(true);
			document.documentElement.classList.add("schedule-dialog-is-open");
			dialog.hidden = false;
			activeDialog = dialog;
			focusDialogTitle(dialog);
			if (document.activeElement === lastFocusedElement) {
				dialog.querySelector<HTMLElement>("[data-schedule-dialog-close]")?.focus({ preventScroll: true });
			}
		};

		document.addEventListener(
			"click",
			event => {
				if (!(event.target instanceof Element)) return;

				const trigger = event.target.closest<HTMLElement>("[data-schedule-event-trigger]");
				const closeButton = event.target.closest<HTMLElement>("[data-schedule-dialog-close]");

				if (trigger) {
					const dialog = dialogs.get(trigger.dataset.scheduleEventTrigger ?? "");
					if (dialog) {
						openDialog(dialog);
					}
					return;
				}

				if (closeButton) {
					closeDialog(closeButton.closest<HTMLElement>("[data-schedule-dialog]"));
				}
			},
			{ signal }
		);

		document.addEventListener(
			"keydown",
			event => {
				if (event.key === "Escape" && activeDialog) {
					closeDialog();
					return;
				}

				if (event.key !== "Tab" || !activeDialog) {
					return;
				}

				const focusables = getFocusableElements(activeDialog);

				if (focusables.length === 0) {
					event.preventDefault();
					return;
				}

				const currentIndex = focusables.indexOf(document.activeElement as HTMLElement);
				const nextIndex = event.shiftKey ? (currentIndex <= 0 ? focusables.length - 1 : currentIndex - 1) : currentIndex === -1 || currentIndex === focusables.length - 1 ? 0 : currentIndex + 1;

				event.preventDefault();
				focusables[nextIndex]?.focus({ preventScroll: true });
			},
			{ signal }
		);

		document.addEventListener(
			"focusin",
			event => {
				if (!activeDialog || !(event.target instanceof Node) || activeDialog.contains(event.target)) return;

				const focusables = getFocusableElements(activeDialog);
				(focusables[0] ?? activeDialog.querySelector<HTMLElement>("[data-schedule-dialog-close]"))?.focus({ preventScroll: true });
			},
			{ signal }
		);

		dialogs.forEach(dialog => {
			dialog.addEventListener(
				"click",
				event => {
					if (event.target === dialog) {
						closeDialog(dialog);
					}
				},
				{ signal }
			);
		});
	});
</script>

<style>
	.schedule-page {
		overflow: hidden;
		padding-block: clamp(8.25rem, 12vw, 12rem) clamp(3.5rem, 7vw, 6rem);
		background: var(--color-background);
		color: var(--color-foreground);
	}

	:global(html),
	:global(body) {
		overflow-x: hidden;
	}

	@supports (overflow-x: clip) {
		:global(html),
		:global(body) {
			overflow-x: clip;
		}
	}

	:global(html.schedule-dialog-is-open) {
		overflow: hidden;
		overscroll-behavior: none;
	}

	:global(html.schedule-dialog-is-open body) {
		overflow: hidden;
		overscroll-behavior: none;
	}

	.schedule-hero {
		display: grid;
		gap: clamp(1rem, 2vw, 1.5rem);
		max-width: var(--site-content-max);
	}

	.schedule-hero__eyebrow {
		width: fit-content;
		margin: 0;
		padding: 0.55rem 0.85rem;
		background: var(--color-green);
		font-size: clamp(1rem, 1.4vw, 1.25rem);
		font-weight: 800;
		line-height: 1;
	}

	.schedule-hero__title {
		margin: 0;
		font-size: clamp(3rem, 8vw, 6.8rem);
		font-weight: 800;
		letter-spacing: 0;
		line-height: 1.02;
		text-wrap: balance;
	}

	.schedule-hero__lead {
		max-width: var(--site-content-max);
		margin: 0;
		color: color-mix(in srgb, var(--color-foreground) 76%, transparent);
		font-size: clamp(1.1rem, 2vw, 1.45rem);
		font-weight: 700;
		line-height: 1.65;
	}

	.schedule-board {
		display: grid;
		grid-template-columns: clamp(3.25rem, 5vw, 4.25rem) minmax(0, 1fr);
		gap: clamp(0.75rem, 1.2vw, 1rem);
		width: 100%;
		max-width: 100%;
		min-width: 0;
		margin-block-start: clamp(2.5rem, 5vw, 4.5rem);
		--schedule-row-gap: clamp(0.32rem, 0.65vw, 0.52rem);
		--schedule-header-row: clamp(5.5rem, 7.4vw, 6.8rem);
		--schedule-slot-row: clamp(4.6rem, 5.7vw, 5.65rem);
	}

	.schedule-time-rail {
		display: grid;
		grid-template-rows: var(--schedule-header-row) repeat(14, var(--schedule-slot-row));
		gap: var(--schedule-row-gap);
	}

	.schedule-time-rail__spacer {
		border: 3px solid transparent;
	}

	.schedule-time-rail__period {
		display: grid;
		place-items: center;
		padding: 0.45rem 0.2rem;
		color: var(--color-background);
		background: var(--color-foreground);
		border-radius: 0.85rem 0;
		font-size: clamp(0.82rem, 1vw, 1rem);
		font-weight: 800;
		line-height: 1;
		box-shadow: 0.14rem 0.14rem 0 0 var(--color-orange);
	}

	.schedule-days-track {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: clamp(0.75rem, 1.2vw, 1rem);
		width: 100%;
		max-width: 100%;
		min-width: 0;
	}

	.schedule-days-track {
		scrollbar-color: var(--color-foreground) color-mix(in srgb, var(--color-foreground) 14%, transparent);
		scrollbar-width: thin;
	}

	.schedule-days-track::-webkit-scrollbar {
		height: 0.55rem;
	}

	.schedule-days-track::-webkit-scrollbar-track {
		background: color-mix(in srgb, var(--color-foreground) 14%, transparent);
		border-radius: 999rem;
	}

	.schedule-days-track::-webkit-scrollbar-thumb {
		background: var(--color-foreground);
		border-radius: 999rem;
	}

	.schedule-day {
		display: grid;
		grid-template-rows: var(--schedule-header-row) repeat(14, var(--schedule-slot-row));
		gap: var(--schedule-row-gap);
		min-width: 0;
		overflow: hidden;
		background: var(--color-foreground);
		border: 3px solid var(--color-foreground);
		border-radius: 1.4rem 0;
		box-shadow: 0.28rem 0.28rem 0 0 var(--day-accent);
		transition:
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.schedule-day--green {
		--day-accent: var(--color-green);
	}

	.schedule-day--blue {
		--day-accent: var(--color-primary-blue);
	}

	.schedule-day--sky {
		--day-accent: var(--color-soft-blue);
	}

	.schedule-day--orange {
		--day-accent: var(--color-orange);
	}

	.schedule-day--dark {
		--day-accent: var(--color-dark-green);
	}

	.schedule-day__header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.45rem;
		padding: clamp(0.65rem, 1.2vw, 1rem);
		color: var(--color-background);
		background: var(--day-accent);
	}

	.schedule-day__header-copy {
		display: grid;
		min-width: 0;
		gap: 0.45rem;
	}

	.schedule-day--blue .schedule-day__header,
	.schedule-day--dark .schedule-day__header {
		color: var(--color-background);
	}

	.schedule-day--green .schedule-day__header,
	.schedule-day--orange .schedule-day__header,
	.schedule-day--sky .schedule-day__header {
		color: var(--color-foreground);
	}

	.schedule-day__subtitle,
	.schedule-day__title {
		margin: 0;
	}

	.schedule-day__subtitle {
		font-size: clamp(0.68rem, 0.8vw, 0.82rem);
		font-weight: 800;
		line-height: 1.2;
		opacity: 0.82;
	}

	.schedule-day__title {
		font-size: clamp(1.25rem, 1.65vw, 1.72rem);
		font-weight: 800;
		line-height: 1.15;
	}

	.schedule-day__blocks {
		display: contents;
	}

	.schedule-block {
		display: grid;
		grid-row: var(--schedule-block-row) / span var(--schedule-block-span);
		min-height: 0;
		padding: clamp(0.28rem, 0.55vw, 0.46rem);
		box-shadow: inset 0 3px 0 0 var(--color-foreground);
	}

	.schedule-block__period {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
		clip-path: inset(50%);
		white-space: nowrap;
		margin: 0;
	}

	.schedule-block__events {
		display: grid;
		grid-auto-rows: minmax(0, 1fr);
		gap: 0;
		height: 100%;
		min-height: 0;
	}

	.schedule-block__empty-text {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 100%;
		margin: 0;
		padding: 0.8rem;
		color: color-mix(in srgb, var(--color-background) 72%, transparent);
		border: 2px dashed color-mix(in srgb, var(--color-background) 34%, transparent);
		border-radius: 0.7rem 0;
		font-size: 0.95rem;
		font-weight: 800;
		line-height: 1.45;
		text-align: center;
	}

	.schedule-event {
		position: relative;
		display: grid;
		grid-template-rows: minmax(0, 1fr);
		width: 100%;
		height: 100%;
		min-height: 0;
		padding: 0;
		color: var(--color-foreground);
		text-align: left;
		cursor: pointer;
		background: var(--color-background);
		border: 0;
		border-radius: 0.72rem 0;
		box-shadow: 0.16rem 0.16rem 0 0 var(--day-accent);
		transition:
			transform 160ms ease,
			box-shadow 160ms ease,
			background 160ms ease;
	}

	.schedule-event__body {
		display: flex;
		flex-direction: column;
		justify-content: center;
		height: 100%;
		min-height: 0;
		padding: clamp(0.5rem, 0.72vw, 0.7rem);
	}

	.schedule-event__content {
		display: flex;
		flex-direction: column;
		gap: clamp(0.18rem, 0.32vw, 0.32rem);
	}

	.schedule-event:not(.schedule-event--static):hover,
	.schedule-event:focus-visible {
		background: color-mix(in srgb, var(--color-background) 86%, white);
		transform: translate(-0.08rem, -0.08rem);
		box-shadow: 0.28rem 0.28rem 0 0 var(--day-accent);
	}

	.schedule-event--static {
		cursor: default;
	}

	.schedule-event--green {
		background: color-mix(in srgb, var(--color-green) 42%, var(--color-background));
	}

	.schedule-event--blue {
		background: color-mix(in srgb, var(--color-soft-blue) 58%, var(--color-background));
	}

	.schedule-event--orange {
		background: color-mix(in srgb, var(--color-orange) 42%, var(--color-background));
	}

	.schedule-event--cream {
		background: rgb(255 244 202);
	}

	.schedule-event--lavender {
		background: rgb(219 211 237);
	}

	.schedule-event--dark {
		color: var(--color-foreground);
		background: color-mix(in srgb, var(--color-green) 56%, var(--color-background));
	}

	.schedule-event--dark .schedule-event__summary {
		color: color-mix(in srgb, var(--color-foreground) 68%, transparent);
	}

	.schedule-event:focus-visible,
	.schedule-dialog__close:focus-visible {
		outline: 0.2rem solid var(--color-soft-blue);
		outline-offset: 0.18rem;
	}

	.schedule-event__badge,

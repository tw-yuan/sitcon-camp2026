---
import homeData from "@/data/home.json";
import ChevronDown from "~icons/lucide/chevron-down";

const { faq } = homeData;
---

<main class="bg-background flex flex-col items-center pt-[clamp(8rem,10vw,10rem)] pb-[clamp(4rem,8.47vw,8rem)]">
	<div class="site-container w-full">
		<h1 class="text-center text-[clamp(1.75rem,4.44vw,4rem)] leading-[150%] font-extrabold text-black">
			{faq.title}
		</h1>

		<div class="mx-auto mt-[clamp(2.5rem,8.47vw,8rem)] flex w-full max-w-3xl flex-col gap-3 sm:gap-4 lg:gap-5">
			{
				faq.items.map(({ question, answer }) => (
					<details class="faq-item w-full">
						<summary class="faq-summary bg-soft-blue text-background flex min-h-12 cursor-pointer items-center justify-between gap-3 rounded-xl px-3 py-2.5 text-[clamp(0.875rem,1.587vw,1.5rem)] leading-[150%] font-extrabold transition-all duration-200 hover:brightness-95 active:scale-[0.99] sm:min-h-[4.25rem] sm:rounded-2xl sm:px-4 sm:py-4 md:px-6 lg:min-h-20 [&::-webkit-details-marker]:hidden">
							<span>
								<span class="text-background/70">{faq.questionPrefix}</span>
								{question}
							</span>
							<ChevronDown class="faq-icon h-4 w-4 shrink-0 transition-transform duration-300 sm:h-5 sm:w-5 md:h-6 md:w-6" />
						</summary>
						<div class="faq-body overflow-hidden" style="height: 0">
							<div class="bg-foreground text-background mt-1.5 rounded-xl px-3 py-2.5 text-[clamp(0.875rem,1.2vw,1.125rem)] leading-[150%] font-normal sm:mt-2 sm:rounded-2xl sm:px-5 sm:py-4 md:px-7 md:py-5">
								<span class="text-background font-extrabold">{faq.answerPrefix}</span>
								{answer}
							</div>
						</div>
					</details>
				))
			}
		</div>
	</div>
</main>

<script>
	document.querySelectorAll<HTMLDetailsElement>(".faq-item").forEach(details => {
		const summary = details.querySelector("summary")!;
		const body = details.querySelector<HTMLElement>(".faq-body")!;
		const icon = details.querySelector<HTMLElement>(".faq-icon")!;
		let animating = false;

		summary.addEventListener("click", e => {
			e.preventDefault();
			if (animating) return;
			animating = true;

			const isOpen = details.open;

			if (!isOpen) {
				details.open = true;
				body.style.height = "0";
				const target = body.scrollHeight + "px";
				icon.style.transform = "rotate(180deg)";
				body.animate([{ height: "0px" }, { height: target }], { duration: 320, easing: "cubic-bezier(0.4,0,0.2,1)" }).onfinish = () => {
					body.style.height = "auto";
					animating = false;
				};
			} else {
				body.style.height = body.scrollHeight + "px";
				icon.style.transform = "rotate(0deg)";
				body.animate([{ height: body.style.height }, { height: "0px" }], { duration: 280, easing: "cubic-bezier(0.4,0,0.2,1)" }).onfinish = () => {
					body.style.height = "0";
					details.open = false;
					animating = false;
				};
			}
		});
	});
</script>

---
import homeData from "@/data/home.json";
import { renderMarkdown } from "@/utils/markdown";
import ChevronDown from "~icons/lucide/chevron-down";

const { faq } = homeData;
---

<main class="bg-background flex flex-col items-center pt-32 pb-16 sm:pt-36 sm:pb-20 lg:pt-40 lg:pb-32">
	<div class="site-container w-full">
		<h1 class="text-center text-5xl leading-[150%] font-extrabold text-black lg:text-[4rem]">
			{faq.title}
		</h1>

		<div class="mx-auto mt-10 flex w-full max-w-3xl flex-col gap-3 sm:mt-16 sm:gap-4 lg:mt-32 lg:gap-5">
			{
				faq.items.map(({ question, answer }) => (
					<details class="faq-item w-full">
						<summary class="faq-summary bg-soft-blue text-background flex min-h-16 cursor-pointer items-center justify-between gap-3 rounded-xl px-4 py-3 text-xl leading-[150%] font-extrabold transition-all duration-200 hover:brightness-95 active:scale-[0.99] sm:min-h-[4.25rem] sm:rounded-2xl sm:px-4 sm:py-4 md:px-6 lg:min-h-20 lg:text-2xl [&::-webkit-details-marker]:hidden">
							<span>
								<span class="text-background/70">{faq.questionPrefix}</span>
								{question}
							</span>
							<ChevronDown class="faq-icon h-4 w-4 shrink-0 transition-transform duration-300 sm:h-5 sm:w-5 md:h-6 md:w-6" />
						</summary>
						<div class="faq-body overflow-hidden" style="height: 0">
							<div class="bg-foreground text-background mt-1.5 flex gap-1.5 rounded-xl px-4 py-3 text-lg leading-[160%] font-normal sm:mt-2 sm:rounded-2xl sm:px-5 sm:py-4 md:px-7 md:py-5">
								<span class="text-background shrink-0 font-extrabold">{faq.answerPrefix}</span>
								<div class="faq-answer min-w-0" set:html={renderMarkdown(answer)} />
							</div>
						</div>
					</details>
				))
			}
		</div>
	</div>
</main>

<script>
	document.querySelectorAll<HTMLDetailsElement>(".faq-item").forEach(details => {
		const summary = details.querySelector("summary")!;
		const body = details.querySelector<HTMLElement>(".faq-body")!;
		const icon = details.querySelector<HTMLElement>(".faq-icon")!;
		let animating = false;

		summary.addEventListener("click", e => {
			e.preventDefault();
			if (animating) return;
			animating = true;

			const isOpen = details.open;

			if (!isOpen) {
				details.open = true;
				body.style.height = "0";
				const target = body.scrollHeight + "px";
				icon.style.transform = "rotate(180deg)";
				body.animate([{ height: "0px" }, { height: target }], { duration: 320, easing: "cubic-bezier(0.4,0,0.2,1)" }).onfinish = () => {
					body.style.height = "auto";
					animating = false;
				};
			} else {
				body.style.height = body.scrollHeight + "px";
				icon.style.transform = "rotate(0deg)";
				body.animate([{ height: body.style.height }, { height: "0px" }], { duration: 280, easing: "cubic-bezier(0.4,0,0.2,1)" }).onfinish = () => {
					body.style.height = "0";
					details.open = false;
					animating = false;
				};
			}
		});
	});
</script>

<style>
	.faq-answer :global(:first-child) {
		margin-top: 0;
	}

	.faq-answer :global(:last-child) {
		margin-bottom: 0;
	}

	.faq-answer :global(p) {
		margin-block: 0.5rem;
	}

	.faq-answer :global(ul),
	.faq-answer :global(ol) {
		margin-block: 0.5rem;
		padding-inline-start: 1.4rem;
	}

	.faq-answer :global(ul) {
		list-style: disc;
	}

	.faq-answer :global(ol) {
		list-style: decimal;
	}

	.faq-answer :global(a) {
		@apply underline underline-offset-2 hover:opacity-80;
	}
</style>

		padding: 0.5rem;
	}

	@media (max-width: 58rem) {
		.roc-schedule {
			padding: 5.4rem 0.32rem 0.75rem;
			overflow-x: hidden;
		}

		.roc-page-title,
		.roc-alert,
		.roc-section,
		.roc-table-scroll {
			box-shadow: 1px 1px 0 #8a8a8a;
		}

		.roc-table-scroll {
			overflow: visible;
		}

		.roc-schedule-table,
		.roc-detail-table,
		.roc-schedule-table thead,
		.roc-detail-table thead,
		.roc-schedule-table tbody,
		.roc-detail-table tbody,
		.roc-schedule-table tr,
		.roc-detail-table tr,
		.roc-schedule-table th,
		.roc-detail-table th,
		.roc-schedule-table td,
		.roc-detail-table td {
			display: block;
			min-width: 0;
			width: 100%;
			box-sizing: border-box;
		}

		.roc-schedule-table thead,
		.roc-detail-table thead {
			position: absolute;
			width: 1px;
			height: 1px;
			overflow: hidden;
			clip: rect(0 0 0 0);
		}

		.roc-schedule-table tr,
		.roc-detail-table tr {
			margin-bottom: 0.45rem;
			border: 2px solid #777;
		}


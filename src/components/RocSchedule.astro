			border-width: 0 0 1px;
		}

		.roc-schedule-table td,
		.roc-detail-table td {
			display: grid;
			grid-template-columns: 5.8rem minmax(0, 1fr);
			gap: 0.35rem;
			border-width: 0 0 1px;
		}

		.roc-schedule-table td:nth-child(2)::before {
			content: "Day 1";
			font-weight: 900;
		}

		.roc-schedule-table td:nth-child(3)::before {

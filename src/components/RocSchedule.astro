		padding: 0.36rem 0.42rem;
		border: 1px solid #777;
		text-align: left;
		vertical-align: top;
	}

	.roc-schedule-table thead th,
	.roc-detail-table thead th {
		color: #fff;
		background: linear-gradient(180deg, #565656, #222);
		text-shadow: 1px 1px 0 #000;
	}

	.roc-schedule-table tbody th {
		color: #001f7d;
		background: #e1ebff;
		white-space: nowrap;
	}

	.roc-schedule-table tbody tr:nth-child(odd) td,
	.roc-detail-table tbody tr:nth-child(odd) {
		background: #f3f6ff;
	}

	.roc-schedule-table tbody tr:nth-child(even) td,

			font-weight: 900;
		}

		.roc-schedule-table td:nth-child(5)::before {
			content: "Day 4";
			font-weight: 900;
		}

		.roc-schedule-table td:nth-child(6)::before {
			content: "Day 5";
			font-weight: 900;
		}

		.roc-detail-table td:nth-child(1)::before {
			content: "類別";
			font-weight: 900;
		}

		.roc-detail-table td:nth-child(2)::before {
			content: "活動名稱";
			font-weight: 900;
		}

		.roc-detail-table td:nth-child(3)::before {
			content: "內容摘要";
			font-weight: 900;
		}
	}

	@media (max-width: 28rem) {
		.roc-schedule-table td,
		.roc-detail-table td {
			grid-template-columns: 1fr;
		}
	}
</style>

---
import type { ImageMetadata } from "astro";
import aboutData from "@/data/about.json";

type Org = {
	name: string;
	role?: string;
	description?: string;
	iconPath: string;
};

const isOrg = (v: unknown): v is Org => {
	if (typeof v !== "object" || v === null) return false;
	const r = v as Record<string, unknown>;
	return typeof r.name === "string" && typeof r.iconPath === "string";
};

type OrganizerBrandAsset = ImageMetadata | string;

const organizerBrandGlob = import.meta.glob<{ default: OrganizerBrandAsset }>("../assets/organizer-brand/*", { eager: true });

function getSrc(iconPath: string): string {
	const file = iconPath.split("/").pop();
	const asset = organizerBrandGlob[`../assets/organizer-brand/${file}`]?.default;
	return typeof asset === "string" ? asset : (asset?.src ?? iconPath);
}

type ResolvedOrg = Org & { src: string };

function resolve(org: Org): ResolvedOrg {
	return { ...org, src: getSrc(org.iconPath) };
}

const sections = aboutData.organizerBrands.sections
	.map(({ tag, items }): [string, Org[]] => [tag, (items as unknown[]).filter(isOrg)])
	.filter(([, list]) => list.length > 0)
	.map(([tag, items]) => [tag, items.map(resolve)] as [string, ResolvedOrg[]]);
---

<div class="bg-background py-20">
	<div class="site-container">
		{
			sections.map(([tag, items]) => (
				<section class="mt-12 first:mt-0 md:mt-24 lg:mt-32">
					<h2 class="mb-4 text-center text-3xl font-bold md:text-left md:text-4xl lg:text-[3rem]">{tag}</h2>
					<div class="flex flex-wrap items-center justify-center gap-8 gap-y-10 sm:gap-10 md:justify-start lg:gap-12">
						{items.map(org => {
							const logoClass = "h-full w-auto max-w-full object-contain";
							const logo = <img src={org.src} alt={org.name} class={logoClass} loading="lazy" decoding="async" />;

							return <div class="org-card group flex h-16 items-center justify-center">{logo}</div>;
						})}
					</div>
				</section>
			))
		}
	</div>
</div>

                                <Image
                                    src={data.AvatarImgUrl}
                                    alt={"avatar"}
                                    width={150}
                                    height={150}
                                    class="border-foreground mx-auto w-full max-w-[150px] max-h-[150px] rounded-xl border-4 shadow-[4px_4px_0_2px_#60A7D5] transition-all duration-300 hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-[2px_2px_0_2px_#60A7D5]"
                                    data-member-id={data.Name} 
                                    data-member={JSON.stringify({ Name: data.Name, Description: data.Description, AvatarLink: data.AvatarLink, AvatarImgUrl: data.AvatarImgUrl })}
                                />
                                <div class="hidden h-[150px] w-[150px]" id={`b-${data.Name}`} />
                                <div class="mt-4 flex h-fit w-full items-center justify-between gap-2">
                                    <h3 class="text-xl font-bold">{data.Name}</h3>
                                    <div class="bg-foreground flex h-fit w-fit items-center justify-center rounded-full px-2 py-0.5">
                                        <p class="text-sm text-white">#{data.Job}</p>
                                    </div>
                                </div>
                            </article>
                        ))

					id="layout-avatar"
				/>
				<div class="flex h-full w-full flex-col justify-between">
					<h1 class="text-6xl font-bold" id="layout-name">PLACEHOLDER</h1>
					<p class="text-foreground my-4 text-xl font-bold" id="layout-des">PLACEHOLDER</p>
					<a class="text-blue mt-auto text-lg font-bold underline underline-offset-3" id="layout-link" href="https://example.com/longdragon" target="_blank" rel="noopener noreferrer">PLACEHOLDER</a>
				</div>
			</section>
			<div class="absolute top-0 right-0 flex h-12 w-16 items-center justify-center rounded-bl-4xl bg-red-500 transition-all duration-300 hover:scale-105" id="layout-cancel">
				<LucideX class="text-foreground h-10 w-10" />
			</div>
		</div>
	</div>

	<section>
		<h1 class="bg-green h-fit w-fit p-3 text-5xl font-bold text-black">團隊成員</h1>

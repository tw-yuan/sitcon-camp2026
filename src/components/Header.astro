---
import Menu from "~icons/lucide/menu";
import X from "~icons/lucide/x";
import SitconCampLogo from "@/assets/SITCONCampLogo.svg";
import layoutData from "@/data/layout.json";

const { header } = layoutData;
---

<header class="site-header" data-site-header aria-label={header.ariaLabel}>
	<a class="site-header__brand" href={header.brand.href} aria-label={header.brand.ariaLabel}>
		<img class="site-header__logo" src={SitconCampLogo.src} width={SitconCampLogo.width} height={SitconCampLogo.height} alt={header.brand.logoAlt} />
	</a>

	<nav class="site-header__nav" aria-label={header.navAriaLabel}>
		{
			header.navItems.map(item => (
				<a class="site-header__link" href={item.href}>
					{item.label}
				</a>
			))
		}
	</nav>

	<a class="site-header__cta" href={header.cta.href}>{header.cta.label}</a>

	<details class="site-header__mobile-menu" data-mobile-menu>
		<summary
			class="site-header__mobile-trigger"
			data-mobile-trigger
			data-mobile-open-label={header.mobileMenu.openLabel}
			data-mobile-close-label={header.mobileMenu.closeLabel}
			aria-label={header.mobileMenu.openLabel}
			aria-expanded="false"
		>
			<span class="site-header__mobile-icon" aria-hidden="true">
				<Menu class="site-header__mobile-icon-glyph site-header__mobile-icon-glyph--menu" width={30} height={30} stroke-width={3} />
				<X class="site-header__mobile-icon-glyph site-header__mobile-icon-glyph--close" width={30} height={30} stroke-width={3} />
			</span>
		</summary>
		<div class="site-header__mobile-panel" data-mobile-panel>
			<nav class="site-header__mobile-nav" aria-label={header.navAriaLabel}>
				{
					header.navItems.map(item => (
						<a class="site-header__mobile-link" data-mobile-menu-link href={item.href}>
							{item.label}
						</a>
					))
				}
				<a class="site-header__mobile-cta" data-mobile-menu-link href={header.cta.href}>{header.cta.label}</a>
			</nav>
		</div>
	</details>
</header>

<script>
	import { animate } from "animejs";

	const siteHeader = document.querySelector<HTMLElement>("[data-site-header]");

	if (siteHeader) {
		const revealHeader = () => {
			siteHeader.classList.add("is-visible");
		};
		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const heroIntro = document.querySelector<HTMLElement>("[data-hero-intro]");
		const shouldWaitForHeroIntro = document.documentElement.classList.contains("hero-intro-lock") || Boolean(heroIntro && !heroIntro.hidden);

		if (prefersReducedMotion) {
			revealHeader();
		} else if (shouldWaitForHeroIntro) {
			let heroIntroRevealTimeout: number | undefined;
			let didRevealAfterHeroIntro = false;

			const revealHeaderAfterHeroIntro = () => {
				if (didRevealAfterHeroIntro) {
					return;
				}

				didRevealAfterHeroIntro = true;

				if (heroIntroRevealTimeout !== undefined) {
					window.clearTimeout(heroIntroRevealTimeout);
					heroIntroRevealTimeout = undefined;
				}

				window.removeEventListener("hero-intro:finished", revealHeaderAfterHeroIntro);
				revealHeader();
			};

			window.addEventListener("hero-intro:finished", revealHeaderAfterHeroIntro, {
				once: true
			});
			heroIntroRevealTimeout = window.setTimeout(revealHeaderAfterHeroIntro, 5000);
		} else {
			requestAnimationFrame(() => {
				window.setTimeout(revealHeader, 120);
			});
		}
	}

	const mobileMenu = document.querySelector<HTMLDetailsElement>("[data-mobile-menu]");
	const mobileTrigger = mobileMenu?.querySelector<HTMLElement>("[data-mobile-trigger]");
	const mobilePanel = mobileMenu?.querySelector<HTMLElement>("[data-mobile-panel]");
	const mobileMenuIcon = mobileMenu?.querySelector<SVGElement>(".site-header__mobile-icon-glyph--menu");
	const mobileCloseIcon = mobileMenu?.querySelector<SVGElement>(".site-header__mobile-icon-glyph--close");
	const mobileLinks = mobileMenu ? Array.from(mobileMenu.querySelectorAll<HTMLAnchorElement>("[data-mobile-menu-link]")) : [];
	const mobileOpenLabel = mobileTrigger?.dataset.mobileOpenLabel || mobileTrigger?.getAttribute("aria-label") || "";
	const mobileCloseLabel = mobileTrigger?.dataset.mobileCloseLabel || mobileOpenLabel;
	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	let mobileMenuAnimating = false;

	const setMobileIconState = (isOpen: boolean) => {
		if (!mobileMenuIcon || !mobileCloseIcon) {
			return;
		}

		if (prefersReducedMotion) {
			Object.assign(mobileMenuIcon.style, {
				opacity: isOpen ? "0" : "1",
				transform: isOpen ? "rotate(90deg) scale(0.7)" : "rotate(0deg) scale(1)"
			});
			Object.assign(mobileCloseIcon.style, {
				opacity: isOpen ? "1" : "0",
				transform: isOpen ? "rotate(0deg) scale(1)" : "rotate(-90deg) scale(0.7)"
			});
			return;
		}

		animate(mobileMenuIcon, {
			opacity: isOpen ? 0 : 1,
			rotate: isOpen ? "90deg" : "0deg",
			scale: isOpen ? 0.7 : 1,
			duration: 240,
			ease: "out(3)"
		});
		animate(mobileCloseIcon, {
			opacity: isOpen ? 1 : 0,
			rotate: isOpen ? "0deg" : "-90deg",
			scale: isOpen ? 1 : 0.7,
			duration: 240,
			ease: "out(3)"
		});
	};

	const setMobileTriggerState = (isOpen: boolean) => {
		if (!mobileTrigger) {
			return;
		}

		mobileTrigger.setAttribute("aria-expanded", String(isOpen));
		mobileTrigger.setAttribute("aria-label", isOpen ? mobileCloseLabel : mobileOpenLabel);
	};

	const openMobileMenu = async () => {
		if (!mobileMenu || !mobilePanel || mobileMenuAnimating || mobileMenu.open) {
			return;
		}

		mobileMenuAnimating = true;
		mobileMenu.open = true;
		setMobileTriggerState(true);
		setMobileIconState(true);

		mobilePanel.style.height = "0";
		mobilePanel.style.opacity = "0";

		if (prefersReducedMotion) {
			mobilePanel.style.height = "auto";
			mobilePanel.style.opacity = "1";
			mobileMenuAnimating = false;
			return;
		}

		await animate(mobilePanel, {
			height: `${mobilePanel.scrollHeight}px`,
			opacity: [0, 1],
			duration: 420,
			ease: "inOutCubic"
		}).then();

		mobilePanel.style.height = "auto";
		mobileMenuAnimating = false;
	};

	const closeMobileMenu = async () => {
		if (!mobileMenu || !mobilePanel || mobileMenuAnimating || !mobileMenu.open) {
			return;
		}

		mobileMenuAnimating = true;
		setMobileTriggerState(false);
		setMobileIconState(false);
		mobilePanel.style.height = `${mobilePanel.scrollHeight}px`;

		if (prefersReducedMotion) {
			mobileMenu.open = false;
			mobilePanel.style.height = "";
			mobilePanel.style.opacity = "";
			mobileMenuAnimating = false;
			return;
		}

		await animate(mobilePanel, {
			height: "0",
			opacity: [1, 0],
			duration: 320,
			ease: "inOutCubic"
		}).then();

		mobileMenu.open = false;
		mobilePanel.style.height = "";
		mobilePanel.style.opacity = "";
		mobileMenuAnimating = false;
	};

	if (mobileMenu && mobileTrigger && mobilePanel) {
		mobilePanel.style.height = "0";
		mobilePanel.style.opacity = "0";

		mobileTrigger.addEventListener("click", event => {
			event.preventDefault();

			if (mobileMenu.open) {
				void closeMobileMenu();
			} else {
				void openMobileMenu();
			}
		});

		mobileLinks.forEach(link => {
			link.addEventListener("click", () => {
				void closeMobileMenu();
			});
		});
	}
</script>

<style>
	.site-header {
		position: fixed;
		inset-block-start: clamp(0.45rem, 1vw, 0.8rem);
		inset-inline-start: 50%;
		z-index: 1000;
		box-sizing: border-box;
		display: flex;
		align-items: center;
		gap: clamp(0.85rem, 1.45vw, 1.8rem);
		width: min(calc(100% - var(--site-content-gutter) - var(--site-content-gutter)), var(--site-content-max));
		min-height: clamp(3.9rem, 5.1vw, 5.9rem);
		padding: clamp(0.55rem, 0.9vw, 1rem) clamp(1.05rem, 2.2vw, 2.25rem);
		color: var(--color-background);
		background: var(--color-foreground);
		border-radius: clamp(1.1rem, 1.7vw, 1.75rem);
		opacity: 0;
		transform: translate3d(-50%, calc(-100% - 1rem), 0);
		transition:
			opacity 220ms ease,
			transform 560ms cubic-bezier(0.22, 1, 0.36, 1);
		will-change: transform, opacity;
	}

	.site-header.is-visible {
		opacity: 1;
		transform: translate3d(-50%, 0, 0);
	}

	.site-header__brand {
		display: inline-flex;
		align-items: center;
		flex: 0 0 auto;
		color: inherit;
		text-decoration: none;
	}

	.site-header__logo {
		display: block;
		width: clamp(7.4rem, 7.7vw, 8.4rem);
		height: auto;
	}

	.site-header__nav {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: clamp(0.85rem, 1.45vw, 1.8rem);
		margin-inline-start: auto;
	}

	.site-header__link,
	.site-header__cta,
	.site-header__mobile-link,
	.site-header__mobile-cta {
		color: inherit;
		font-weight: 800;
		letter-spacing: 0;
		line-height: 1.1;
		text-decoration: none;
		white-space: nowrap;
	}

	.site-header__link {
		font-size: clamp(0.95rem, 1.15vw, 1.35rem);
		transition:
			color 160ms ease,
			transform 160ms ease;
	}

	.site-header__link:hover,
	.site-header__link:focus-visible {
		color: var(--color-soft-blue);
		transform: translateY(-0.08rem);
	}

	.site-header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: clamp(2.45rem, 2.75vw, 3.2rem);
		padding: 0 clamp(1rem, 1.55vw, 1.7rem);
		color: var(--color-foreground);
		background: var(--color-soft-blue);
		border-radius: clamp(0.8rem, 1.1vw, 1.15rem);
		font-size: clamp(1rem, 1.25vw, 1.45rem);
		transition:
			background 160ms ease,
			transform 160ms ease;
	}

	.site-header__cta:hover,
	.site-header__cta:focus-visible,
	.site-header__mobile-cta:hover,
	.site-header__mobile-cta:focus-visible {
		background: var(--color-sky-blue);
		transform: translateY(-0.08rem);
	}

	.site-header__link:focus-visible,
	.site-header__cta:focus-visible,
	.site-header__mobile-trigger:focus-visible,
	.site-header__mobile-link:focus-visible,
	.site-header__mobile-cta:focus-visible {
		outline: 0.16rem solid var(--color-background);
		outline-offset: 0.2rem;
	}

	.site-header__mobile-menu {
		display: none;
		margin-inline-start: auto;
	}

	.site-header__mobile-trigger {
		position: relative;
		display: inline-grid;
		place-items: center;
		width: 3.4rem;
		aspect-ratio: 1;
		color: var(--color-background);
		cursor: pointer;
		list-style: none;
		border-radius: 999rem;
	}

	.site-header__mobile-trigger::-webkit-details-marker {
		display: none;
	}

	.site-header__mobile-icon {
		position: relative;
		display: inline-grid;
		place-items: center;
		width: 1.875rem;
		aspect-ratio: 1;
	}

	.site-header__mobile-icon-glyph {
		grid-area: 1 / 1;
		display: block;
		transform-origin: center;
		will-change: opacity, transform;
	}

	.site-header__mobile-icon-glyph--close {
		opacity: 0;
		transform: rotate(-90deg) scale(0.7);
	}

	.site-header__mobile-menu[open] .site-header__mobile-icon-glyph--menu {
		opacity: 0;
		transform: rotate(90deg) scale(0.7);
	}

	.site-header__mobile-menu[open] .site-header__mobile-icon-glyph--close {
		opacity: 1;
		transform: rotate(0deg) scale(1);
	}

	.site-header__mobile-panel {
		position: absolute;
		inset-block-start: calc(100% + 0.55rem);
		inset-inline: 0;
		overflow: hidden;
		height: 0;
		color: var(--color-background);
		background: var(--color-foreground);
		border-radius: 1.2rem;
		opacity: 0;
		will-change: height, opacity;
	}

	.site-header__mobile-menu[open] .site-header__mobile-panel {
		height: auto;
		opacity: 1;
	}

	.site-header__mobile-nav {
		display: grid;
		gap: 0.4rem;
		padding: 1rem;
	}

	.site-header__mobile-link,
	.site-header__mobile-cta {
		min-height: 3rem;
		padding: 0.9rem 1rem;
		border-radius: 0.8rem;
		font-size: 1.125rem;
	}

	.site-header__mobile-link:hover,
	.site-header__mobile-link:focus-visible {
		color: var(--color-soft-blue);
	}

	.site-header__mobile-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-foreground);
		background: var(--color-soft-blue);
	}

	@media (max-width: 52rem) {
		.site-header {
			min-height: 4.1rem;
			padding: 0.75rem 1rem;
			border-radius: 1.25rem;
		}

		.site-header__logo {
			width: clamp(6.6rem, 24vw, 7.8rem);
		}

		.site-header__nav,
		.site-header__cta {
			display: none;
		}

		.site-header__mobile-menu {
			display: block;
		}
	}

	@media (max-width: 28rem) {
		.site-header {
			inset-block-start: 0.35rem;
			min-height: 3.75rem;
			padding: 0.65rem 0.8rem;
			border-radius: 1rem;
		}

		.site-header__logo {
			width: min(7rem, 50vw);
		}

		.site-header__mobile-trigger {
			width: 2.75rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-header {
			transition: none;
			opacity: 1;
			transform: translate3d(-50%, 0, 0);
		}
	}
</style>

<noscript>
	<style>
		.site-header {
			opacity: 1 !important;
			transform: translate3d(-50%, 0, 0) !important;
		}
	</style>
</noscript>

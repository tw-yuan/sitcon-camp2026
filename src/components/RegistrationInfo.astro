---
import { Image } from "astro:assets";
import registrationPhoto from "@/assets/registration/registration-photo.png";
import CalendarDaysIcon from "~icons/lucide/calendar-days";
import MapPinIcon from "~icons/lucide/map-pin";
import MarkdownIt from "markdown-it";
import homeData from "@/data/home.json";
import DateLine from "@/components/DateLine.astro";

const { registration } = homeData;
const { eventInfo } = registration;
const pricingColorClassMap: Record<string, string> = {
	orange: "text-orange",
	"primary-blue": "text-primary-blue",
	"soft-blue": "text-soft-blue",
	"sky-blue": "text-sky-blue",
	"dark-green": "text-dark-green"
};

const mdRenderer = new MarkdownIt({
	html: false,
	linkify: true,
	breaks: true
});

const renderedNotice = mdRenderer.render(registration.noticeMarkdown);
---

<div class="overflow-hidden">
	<svg id="reg-transition" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="block w-full" aria-hidden="true"></svg>
</div>

<section
	id="registration-info"
	class="bg-foreground pt-(--gap) pb-(--gap) text-white"
	style="--row-h: clamp(3rem, 5.4vw, 5.125rem); --radius: clamp(1.75rem, 4.2vw, 4rem); --gap: clamp(1.5rem, 4.2vw, 4rem); --label-size: clamp(1.0625rem, 2.1vw, 2rem); --heading-size: clamp(1.65rem, 3.25vw, 2.5rem)"
>
	<div class="site-container">
		<div class="bg-green flex w-fit items-center justify-center gap-2.5 p-2.5">
			<span class="text-foreground leading-none font-bold" style="font-size: var(--heading-size)">{registration.sectionTitle}</span>
		</div>

		<div class="bg-soft-blue text-background relative grid w-full overflow-hidden lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.48fr)]" style="margin-top: var(--gap); border-radius: var(--radius) 0">
			<MapPinIcon class="text-background/15 pointer-events-none absolute -right-8 -bottom-14 h-auto w-[clamp(10rem,24vw,18rem)] rotate-[-10deg]" aria-hidden="true" />

			<div class="relative z-10 flex flex-col gap-4 p-[clamp(1.25rem,4vw,3.5rem)]">
				<span class="text-[clamp(0.875rem,1.35vw,1.125rem)] leading-none font-bold opacity-70">{eventInfo.venueLabel}</span>
				<div class="flex flex-col gap-4 sm:flex-row sm:items-center">
					<span class="bg-background text-soft-blue flex size-[clamp(3.25rem,6vw,5rem)] shrink-0 items-center justify-center rounded-full">
						<MapPinIcon class="h-[52%] w-[52%]" aria-hidden="true" />
					</span>
					<div class="flex min-w-0 flex-col gap-2">
						<h3 class="text-[clamp(1.75rem,4vw,3.5rem)] leading-[120%] font-extrabold">{eventInfo.venueName}</h3>
						<p class="text-background/80 text-[clamp(1rem,1.7vw,1.35rem)] leading-[150%] font-bold">{eventInfo.venueDetail}</p>
					</div>
				</div>
			</div>

			<div class="bg-background text-foreground border-foreground/25 relative z-10 flex flex-col justify-center border-t-4 p-[clamp(1.25rem,3vw,2.25rem)] lg:border-t-0 lg:border-l-4">
				<div class="flex items-center gap-3">
					<span class="bg-green flex size-[clamp(2.75rem,4.5vw,3.75rem)] shrink-0 items-center justify-center rounded-full">
						<CalendarDaysIcon class="text-foreground h-[54%] w-[54%]" aria-hidden="true" />
					</span>
					<span class="text-foreground/60 text-[clamp(0.875rem,1.35vw,1.125rem)] leading-none font-bold">{eventInfo.dateLabel}</span>
				</div>
				<strong class="mt-5 text-[clamp(1.5rem,3vw,2.5rem)] leading-[120%] font-extrabold">{eventInfo.dateRange}</strong>
				<span class="text-foreground/70 mt-2 text-[clamp(1rem,1.5vw,1.25rem)] leading-[150%] font-bold">{eventInfo.dateNote}</span>
			</div>
		</div>

		<DateLine variant="c" />

		<div class="flex w-full flex-col items-start lg:flex-row" style="margin-top: var(--gap)">
			<div class="flex w-full flex-col items-start lg:flex-691">
				{
					registration.pricingRows.map(({ label, color, price, roundedStart, roundedEnd }) => (
						<div
							class="bg-background grid w-full grid-cols-2 items-center border-y border-black px-[9.262%]"
							style={`height: var(--row-h); ${roundedStart ? "border-top-left-radius: var(--radius);" : ""}${roundedEnd ? "border-bottom-right-radius: var(--radius);" : ""}`}
						>
							<span class:list={["text-center leading-[150%] font-extrabold", pricingColorClassMap[color] ?? "text-orange"]} style="font-size: var(--label-size)">
								{label}
							</span>
							<span class="text-center leading-[150%] font-extrabold text-black" style="font-size: var(--label-size)">
								{price}
							</span>
						</div>
					))
				}
			</div>

			<div class="relative mt-(--gap) aspect-565/410 w-full overflow-hidden lg:mt-0 lg:flex-565">
				<Image src={registrationPhoto} alt={registration.photoAlt} class="absolute top-[6.585%] left-[7.434%] aspect-239/159 w-[85.133%] object-cover" loading="lazy" decoding="async" />
				<div class="absolute right-[4%] bottom-[4.878%] left-[4%] flex justify-center gap-2 sm:right-[8%] sm:left-[8%] sm:gap-3">
					<a
						href={registration.ctaBrochure.href}
						target="_blank"
						rel="noreferrer"
						class="bg-background text-foreground flex h-[clamp(3.5rem,15vw,4.5rem)] w-[min(44vw,13rem)] items-center justify-center rounded-2xl px-3 text-[clamp(1.125rem,5.3vw,2.125rem)] leading-[150%] font-extrabold whitespace-nowrap shadow-[clamp(0.25rem,0.53vw,0.5rem)_clamp(0.25rem,0.53vw,0.5rem)_0_0_var(--color-orange)] sm:w-auto sm:px-4"
					>
						{registration.ctaBrochure.label}
					</a>
					<a
						href={registration.cta.href}
						class="bg-green flex h-[clamp(3.5rem,15vw,4.5rem)] w-[min(44vw,13rem)] items-center justify-center rounded-2xl px-3 text-[clamp(1.125rem,5.3vw,2.125rem)] leading-[150%] font-extrabold whitespace-nowrap text-white shadow-[clamp(0.25rem,0.53vw,0.5rem)_clamp(0.25rem,0.53vw,0.5rem)_0_0_var(--color-orange)] sm:w-auto sm:px-4"
					>
						{registration.cta.label}
					</a>
				</div>
			</div>
		</div>

		<div class="bg-orange flex w-fit items-center justify-center gap-2.5 p-2.5" style="margin-top: var(--gap)">
			<span class="text-foreground leading-none font-bold" style="font-size: var(--heading-size)">{registration.noticeTitle}</span>
		</div>

		<div class="mt-6 text-[clamp(1rem,1.25vw,1.125rem)] leading-[170%] font-bold text-white [&_a]:underline [&_ol]:list-decimal [&_ol]:space-y-1 [&_ol]:pl-6" set:html={renderedNotice} />
	</div>
</section>

<!-- 底部過渡：對角線斜切，上=foreground 下=background -->
<div class="bg-background overflow-hidden">
	<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="bg-background -mt-px block w-full" aria-hidden="true">
		<!-- 多蓋 1px，避免斜切邊緣出現次像素縫隙 -->
		<polygon points="0,-1 1440,-1 0,81" fill="var(--color-foreground)"></polygon>
	</svg>
</div>

<script>
	const svg = document.getElementById("reg-transition")!;
	const ns = "http://www.w3.org/2000/svg";
	const W = 1440,
		H = 60;
	const COUNT = 8;
	const COLOR = getComputedStyle(document.documentElement).getPropertyValue("--color-foreground").trim();

	function rand(min: number, max: number) {
		return Math.random() * (max - min) + min;
	}

	// 底部矩形確保無縫銜接
	const rect = document.createElementNS(ns, "rect");
	rect.setAttribute("x", "0");
	rect.setAttribute("y", String(H * 0.75));
	rect.setAttribute("width", String(W));
	rect.setAttribute("height", String(H));
	rect.setAttribute("fill", COLOR);
	svg.appendChild(rect);

	// 隨機橢圓，分 slot 確保分佈均勻
	const slotW = W / COUNT;
	for (let i = 0; i < COUNT; i++) {
		const el = document.createElementNS(ns, "ellipse");
		el.setAttribute("cx", String(slotW * i + rand(slotW * 0.1, slotW * 0.9)));
		el.setAttribute("cy", String(H));
		el.setAttribute("rx", String(rand(140, 230)));
		el.setAttribute("ry", String(rand(30, 50)));
		el.setAttribute("fill", COLOR);
		svg.appendChild(el);
	}
</script>

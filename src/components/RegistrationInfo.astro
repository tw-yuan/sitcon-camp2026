---
import { Image } from "astro:assets";
import registrationPhoto from "@/assets/registration/registration-photo.png";
import CalendarDaysIcon from "~icons/lucide/calendar-days";
import MapPinIcon from "~icons/lucide/map-pin";
import MarkdownIt from "markdown-it";
import homeData from "@/data/home.json";
import DateLine from "@/components/DateLine.astro";

const { registration } = homeData;
const { eventInfo } = registration;
const pricingColorClassMap: Record<string, string> = {
	orange: "text-orange",
	"primary-blue": "text-primary-blue",
	"soft-blue": "text-soft-blue",
	"sky-blue": "text-sky-blue",
	"dark-green": "text-dark-green"
};

const mdRenderer = new MarkdownIt({
	html: false,
	linkify: true,
	breaks: true
});

const renderedNotice = mdRenderer.render(registration.noticeMarkdown);
---

<div class="overflow-hidden">
	<svg id="reg-transition" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="block w-full" aria-hidden="true"></svg>
</div>

<section id="registration-info" class="bg-foreground py-6 text-white sm:py-10 lg:py-16">
	<div class="site-container">
		<div class="bg-green flex w-fit items-center justify-center gap-2.5 p-2.5">
			<span class="text-foreground text-3xl leading-none font-bold sm:text-4xl lg:text-[2.5rem]">{registration.sectionTitle}</span>
		</div>

		<div
			class="bg-soft-blue text-background relative mt-6 grid w-full overflow-hidden rounded-[1.75rem_0] sm:mt-10 sm:rounded-[2.5rem_0] lg:mt-16 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.48fr)] lg:rounded-[4rem_0]"
		>
			<MapPinIcon class="text-background/15 pointer-events-none absolute -right-8 -bottom-14 h-auto w-40 rotate-[-10deg] sm:w-56 lg:w-72" aria-hidden="true" />

			<div class="relative z-10 flex flex-col gap-4 p-5 sm:p-8 lg:p-14">
				<span class="text-lg leading-none font-bold opacity-70">{eventInfo.venueLabel}</span>
				<div class="flex flex-col gap-4 sm:flex-row sm:items-center">
					<span class="bg-background text-soft-blue flex size-13 shrink-0 items-center justify-center rounded-full sm:size-16 lg:size-20">
						<MapPinIcon class="h-[52%] w-[52%]" aria-hidden="true" />
					</span>
					<div class="flex min-w-0 flex-col gap-2">
						<h3 class="text-4xl leading-[120%] font-extrabold sm:text-5xl lg:text-[3.5rem]">{eventInfo.venueName}</h3>
						<p class="text-background/80 text-lg leading-[150%] font-bold lg:text-[1.35rem]">{eventInfo.venueDetail}</p>
					</div>
				</div>
			</div>

			<div class="bg-background text-foreground border-foreground/25 relative z-10 flex flex-col justify-center border-t-4 p-5 sm:p-7 lg:border-t-0 lg:border-l-4 lg:p-9">
				<div class="flex items-center gap-3">
					<span class="bg-green flex size-12 shrink-0 items-center justify-center rounded-full sm:size-14 lg:size-[3.75rem]">
						<CalendarDaysIcon class="text-foreground h-[54%] w-[54%]" aria-hidden="true" />
					</span>
					<span class="text-foreground/60 text-lg leading-none font-bold">{eventInfo.dateLabel}</span>
				</div>
				<strong class="mt-5 text-3xl leading-[120%] font-extrabold sm:text-4xl lg:text-[2.5rem]">{eventInfo.dateRange}</strong>
				<span class="text-foreground/70 mt-2 text-lg leading-[150%] font-bold lg:text-xl">{eventInfo.dateNote}</span>
			</div>
		</div>

		<DateLine variant="c" />

		<div class="mt-6 flex w-full flex-col items-start sm:mt-10 lg:mt-16 lg:flex-row">
			<div class="flex w-full flex-col items-start lg:flex-691">
				{
					registration.pricingRows.map(({ label, color, price, roundedStart, roundedEnd }) => (
						<div
							class:list={[
								"bg-background grid h-[4.5rem] w-full grid-cols-2 items-center border-y border-black px-[9.262%] sm:h-20 lg:h-[5.125rem]",
								roundedStart && "rounded-tl-[1.75rem] sm:rounded-tl-[2.5rem] lg:rounded-tl-[4rem]",
								roundedEnd && "rounded-br-[1.75rem] sm:rounded-br-[2.5rem] lg:rounded-br-[4rem]"
							]}
						>
							<span class:list={["text-center text-2xl leading-[150%] font-extrabold sm:text-[1.75rem] lg:text-[2rem]", pricingColorClassMap[color] ?? "text-orange"]}>{label}</span>
							<span class="text-center text-2xl leading-[150%] font-extrabold text-black sm:text-[1.75rem] lg:text-[2rem]">{price}</span>
						</div>
					))
				}
			</div>

			<div class="relative mt-6 aspect-565/410 w-full overflow-hidden sm:mt-10 lg:mt-0 lg:flex-565">
				<Image src={registrationPhoto} alt={registration.photoAlt} class="absolute top-[6.585%] left-[7.434%] aspect-239/159 w-[85.133%] object-cover" loading="lazy" decoding="async" />
				<div class="absolute right-[4%] bottom-[4.878%] left-[4%] flex justify-center gap-2 sm:right-[8%] sm:left-[8%] sm:gap-3">
					<a
						href={registration.ctaBrochure.href}
						target="_blank"
						rel="noreferrer"
						class="bg-background text-foreground flex h-14 w-[44vw] max-w-[13rem] items-center justify-center rounded-2xl px-3 text-xl leading-[150%] font-extrabold whitespace-nowrap shadow-[0.25rem_0.25rem_0_0_var(--color-orange)] sm:h-16 sm:w-auto sm:px-4 sm:text-2xl lg:h-[4.5rem] lg:text-[2.125rem] lg:shadow-[0.5rem_0.5rem_0_0_var(--color-orange)]"
					>
						{registration.ctaBrochure.label}
					</a>
					<a
						href={registration.cta.href}
						class="bg-green flex h-14 w-[44vw] max-w-[13rem] items-center justify-center rounded-2xl px-3 text-xl leading-[150%] font-extrabold whitespace-nowrap text-white shadow-[0.25rem_0.25rem_0_0_var(--color-orange)] sm:h-16 sm:w-auto sm:px-4 sm:text-2xl lg:h-[4.5rem] lg:text-[2.125rem] lg:shadow-[0.5rem_0.5rem_0_0_var(--color-orange)]"
					>
						{registration.cta.label}
					</a>
				</div>
			</div>
		</div>

		<div class="bg-orange mt-6 flex w-fit items-center justify-center gap-2.5 p-2.5 sm:mt-10 lg:mt-16">
			<span class="text-foreground text-3xl leading-none font-bold sm:text-4xl lg:text-[2.5rem]">{registration.noticeTitle}</span>
		</div>

		<div class="mt-6 text-lg leading-[170%] font-bold text-white [&_a]:underline [&_ol]:list-decimal [&_ol]:space-y-1 [&_ol]:pl-6" set:html={renderedNotice} />
	</div>
</section>

<!-- 底部過渡：對角線斜切，上=foreground 下=background -->
<div class="bg-background overflow-hidden">
	<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="bg-background -mt-px block w-full" aria-hidden="true">
		<!-- 多蓋 1px，避免斜切邊緣出現次像素縫隙 -->
		<polygon points="0,-1 1440,-1 0,81" fill="var(--color-foreground)"></polygon>
	</svg>
</div>

<script>
	document.addEventListener("astro:page-load", () => {
		const svg = document.getElementById("reg-transition")!;
		if (!svg) return;
		const ns = "http://www.w3.org/2000/svg";
		const W = 1440,
			H = 60;
		const COUNT = 8;
		const COLOR = getComputedStyle(document.documentElement).getPropertyValue("--color-foreground").trim();

		function rand(min: number, max: number) {
			return Math.random() * (max - min) + min;
		}

		// 底部矩形確保無縫銜接
		const rect = document.createElementNS(ns, "rect");
		rect.setAttribute("x", "0");
		rect.setAttribute("y", String(H * 0.75));
		rect.setAttribute("width", String(W));
		rect.setAttribute("height", String(H));
		rect.setAttribute("fill", COLOR);
		svg.appendChild(rect);

		// 隨機橢圓，分 slot 確保分佈均勻
		const slotW = W / COUNT;
		for (let i = 0; i < COUNT; i++) {
			const el = document.createElementNS(ns, "ellipse");
			el.setAttribute("cx", String(slotW * i + rand(slotW * 0.1, slotW * 0.9)));
			el.setAttribute("cy", String(H));
			el.setAttribute("rx", String(rand(140, 230)));
			el.setAttribute("ry", String(rand(30, 50)));
			el.setAttribute("fill", COLOR);
			svg.appendChild(el);
		}
	});
</script>

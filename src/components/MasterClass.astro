---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import homeData from "@/data/home.json";

const { masterClassSection, masterClasses } = homeData;
type MasterClassItem = (typeof masterClasses)[number];

const masterImages = Object.fromEntries(
	Object.entries(
		import.meta.glob<{ default: ImageMetadata }>("../assets/master-class-speakers/*.{avif,jpeg,jpg,png,webp}", {
			eager: true
		})
	).map(([path, image]) => {
		const key = path
			.split("/")
			.pop()
			?.replace(/\.[^.]+$/, "");
		return [key, image.default];
	})
) as Record<string, ImageMetadata>;

const getMasterImage = (masterClass: MasterClassItem) => {
	const image = masterImages[masterClass.imageKey];

	if (!image) {
		throw new Error(`Missing master class speaker image: ${masterClass.imageKey}`);
	}

	return image;
};
const getMasterDetailKey = (masterClass: MasterClassItem) => JSON.stringify([masterClass.title, masterClass.summary, masterClass.outcome]);
const masterClassDetails = masterClasses.map((masterClass, index) => ({
	masterClass,
	index,
	isDuplicate: masterClasses.findIndex(item => getMasterDetailKey(item) === getMasterDetailKey(masterClass)) !== index
}));
---

<section id="master-class" class="master-class" aria-labelledby="master-class-title" data-master-class>
	<div class="master-class__sticky">
		<div class="master-class__content site-container" data-master-content>
			<div class="master-class__intro" data-master-intro>
				<p class="master-class__eyebrow">{masterClassSection.eyebrow}</p>
				<h2 id="master-class-title" class="master-class__title">{masterClassSection.title}</h2>
				<p class="master-class__lead">{masterClassSection.lead}</p>
			</div>

			<div class="master-class__stage" data-master-stage>
				<div class="master-class__deck" aria-label={masterClassSection.deckAriaLabel} data-master-deck>
					{
						masterClasses.map((masterClass, index) => {
							const image = getMasterImage(masterClass);
							const [kickerPrimary, kickerSecondary] = masterClass.kicker.split(" / ");

							return (
								<article class:list={["master-card", `master-card--${masterClass.accent}`]} data-master-card data-master-index={index}>
									<figure class="master-card__media">
										<Image
											src={image}
											alt={`${masterClass.title} ${masterClass.instructor} 講師照片`}
											class="master-card__image"
											loading="lazy"
											decoding="async"
											format="webp"
											style={`object-position: ${masterClass.imagePosition}`}
										/>
									</figure>
									<div class="master-card__body">
										<p class="master-card__kicker">
											<span>{kickerPrimary}</span>
											{kickerSecondary && (
												<>
													<span aria-hidden="true"> / </span>
													<span>{kickerSecondary}</span>
												</>
											)}
										</p>
										<h3 class="master-card__title">{masterClass.instructor}</h3>
										<p class="master-card__achievement">{masterClass.achievement}</p>
										<ul class="master-card__profile" aria-label={`${masterClass.title} 講師履歷亮點`}>
											{masterClass.profile.map(item => (
												<li>{item}</li>
											))}
										</ul>
									</div>
								</article>
							);
						})
					}
				</div>

				<div class="master-class__details" aria-live="polite">
					{
						masterClassDetails.map(({ masterClass, index, isDuplicate }) => (
							<article class:list={["master-detail", `master-detail--${masterClass.accent}`, isDuplicate && "master-detail--mobile-duplicate"]} data-master-detail data-master-index={index}>
								<h3 class="master-detail__title">{masterClass.title}</h3>
								<p class="master-detail__summary">
									{masterClass.summary.map(line => (
										<span>{line}</span>
									))}
								</p>
								<p class="master-detail__outcome">{masterClass.outcome}</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<noscript>
	<style>
		[data-master-card],
		[data-master-detail],
		[data-master-intro] {
			opacity: 1 !important;
			transform: none !important;
		}
	</style>
</noscript>

<script>
	import { animate, onScroll, stagger } from "animejs";

	const section = document.querySelector<HTMLElement>("[data-master-class]");
	const content = section?.querySelector<HTMLElement>("[data-master-content]");
	const intro = section?.querySelector<HTMLElement>("[data-master-intro]");
	const deck = section?.querySelector<HTMLElement>("[data-master-deck]");
	const cards = section ? Array.from(section.querySelectorAll<HTMLElement>("[data-master-card]")) : [];
	const details = section ? Array.from(section.querySelectorAll<HTMLElement>("[data-master-detail]")) : [];
	const desktopQuery = window.matchMedia("(min-width: 72.001rem) and (min-height: 44.001rem)");

	let observer: ReturnType<typeof onScroll> | undefined;
	let mobileRevealObserver: IntersectionObserver | undefined;
	let activeDetailIndex = -1;
	let resizeFrame = 0;

	const clamp = (value: number, min = 0, max = 1) => Math.min(Math.max(value, min), max);
	const lerp = (from: number, to: number, progress: number) => from + (to - from) * progress;
	const easeOutCubic = (value: number) => 1 - Math.pow(1 - value, 3);
	const easeInOutCubic = (value: number) => (value < 0.5 ? 4 * value * value * value : 1 - Math.pow(-2 * value + 2, 3) / 2);

	const setCardTransform = (card: HTMLElement, x: number, y: number, rotate: number, scale: number) => {
		card.style.transform = `translate3d(${x}px, ${y}px, 0) rotate(${rotate}deg) scale(${scale})`;
	};

	const resetInlineStyles = () => {
		observer?.revert();
		observer = undefined;
		mobileRevealObserver?.disconnect();
		mobileRevealObserver = undefined;
		activeDetailIndex = -1;

		cards.forEach(card => {
			card.style.transform = "";
			card.style.opacity = "";
			card.style.zIndex = "";
			card.classList.remove("master-card--active");
		});

		details.forEach(detail => {
			detail.style.transform = "";
			detail.style.opacity = "";
			detail.style.pointerEvents = "";
			detail.classList.remove("master-detail--active");
			detail.setAttribute("aria-hidden", "false");
		});
	};

	const revealMobile = () => {
		resetInlineStyles();

		const revealTargets = [intro, ...cards, ...details].filter(Boolean) as HTMLElement[];
		revealTargets.forEach(target => {
			target.style.opacity = "0";
			target.style.transform = "translate3d(0, 2rem, 0)";
		});

		mobileRevealObserver = new IntersectionObserver(
			entries => {
				entries.forEach(entry => {
					if (!entry.isIntersecting) {
						return;
					}

					const target = entry.target as HTMLElement;
					animate(target, {
						opacity: 1,
						y: 0,
						duration: 620,
						ease: "out(4)"
					});
					mobileRevealObserver?.unobserve(target);
				});
			},
			{ threshold: 0.18 }
		);

		revealTargets.forEach(target => mobileRevealObserver?.observe(target));
	};

	const setActiveDetail = (index: number) => {
		if (activeDetailIndex === index) {
			return;
		}

		activeDetailIndex = index;

		details.forEach((detail, detailIndex) => {
			const isActive = detailIndex === index;
			detail.classList.toggle("master-detail--active", isActive);
			detail.setAttribute("aria-hidden", String(!isActive));
			detail.style.pointerEvents = isActive ? "auto" : "none";

			animate(detail, {
				opacity: isActive ? 1 : 0,
				duration: 420,
				ease: "out(4)"
			});
		});
	};

	const renderDesktop = (progress: number) => {
		const stackProgress = easeInOutCubic(clamp((progress - 0.22) / 0.22));
		const revealProgress = clamp((progress - 0.48) / 0.52);
		const revealStarted = easeOutCubic(clamp((progress - 0.48) / 0.08));
		const activeIndex = Math.min(cards.length - 1, Math.max(0, Math.floor(revealProgress * cards.length)));
		const deckLeft = deck?.getBoundingClientRect().left ?? 0;
		const contentLeft = content?.getBoundingClientRect().left;
		const viewportWidth = window.innerWidth;
		const sideInset = contentLeft ?? clamp(viewportWidth * 0.08, 80, 144);

		cards.forEach((card, index) => {
			const layoutLeft = deckLeft + card.offsetLeft;
			const cardWidth = card.offsetWidth;
			const baseX = 0;
			const baseY = 0;
			const stackLeft = viewportWidth - cardWidth - sideInset - index * 18;
			const activeLeft = sideInset;
			const afterLeft = Math.min(-cardWidth * 0.28 + index * 18, sideInset * 0.35);
			const futureRestLeft = viewportWidth - cardWidth * 0.12 + index * 18;
			const stackX = stackLeft - layoutLeft;
			const futureRestX = futureRestLeft - layoutLeft;
			const stackY = (index - 1) * 28;
			const stackRotate = (index - 1) * 5;
			const stackScale = 0.8 - index * 0.018;
			const cardStart = index / cards.length;
			const cardEnd = (index + 0.92) / cards.length;
			const cardProgress = easeOutCubic(clamp((revealProgress - cardStart) / (cardEnd - cardStart)));
			const activeX = activeLeft - layoutLeft;
			const activeY = 0;
			const afterX = afterLeft - layoutLeft;
			const afterY = -38 - index * 12;
			const afterProgress = index === cards.length - 1 ? 0 : easeOutCubic(clamp((revealProgress - cardEnd) / 0.18));
			const startX = lerp(stackX, futureRestX, revealStarted);
			const targetX = lerp(startX, activeX, cardProgress);
			const targetY = lerp(stackY, activeY, cardProgress);
			const targetRotate = lerp(stackRotate, 0, cardProgress);
			const targetScale = lerp(stackScale, 0.95, cardProgress);
			const finalX = lerp(targetX, afterX, afterProgress);
			const finalY = lerp(targetY, afterY, afterProgress);
			const finalRotate = lerp(targetRotate, -5, afterProgress);
			const finalScale = lerp(targetScale, 0.82, afterProgress);
			const x = lerp(baseX, finalX, stackProgress);
			const y = lerp(baseY, finalY, stackProgress);
			const rotate = lerp(0, finalRotate, stackProgress);
			const scale = lerp(1, finalScale, stackProgress);
			const isActive = progress < 0.48 ? false : index === activeIndex;
			const inactiveOpacity = index < activeIndex ? 0.06 : 0.08;
			const stackOpacity = lerp(1, inactiveOpacity, revealStarted);
			const enteringOpacity = lerp(stackOpacity, 1, cardProgress);
			const finalOpacity = isActive ? enteringOpacity : lerp(enteringOpacity, inactiveOpacity, afterProgress || revealStarted);

			card.style.zIndex = String(isActive ? 20 : 10 - index);
			card.style.opacity = String(finalOpacity);
			card.classList.toggle("master-card--active", isActive);
			setCardTransform(card, x, y, rotate, scale);
		});

		if (progress < 0.48) {
			setActiveDetail(-1);
		} else {
			setActiveDetail(activeIndex);
		}
	};

	const setupDesktop = () => {
		if (!section) {
			return;
		}

		resetInlineStyles();

		details.forEach(detail => {
			detail.style.opacity = "0";
			detail.style.pointerEvents = "none";
			detail.setAttribute("aria-hidden", "true");
		});

		animate(cards, {
			opacity: [0, 1],
			duration: 720,
			delay: stagger(90),
			ease: "out(4)"
		});

		observer = onScroll({
			target: section,
			enter: "start start",
			leave: "end end",
			sync: true,
			onUpdate: self => renderDesktop(self.progress),
			onResize: self => renderDesktop(self.progress)
		});

		renderDesktop(observer.progress);
	};

	const setup = () => {
		if (!section || cards.length === 0 || details.length === 0) {
			return;
		}

		if (desktopQuery.matches) {
			setupDesktop();
		} else {
			revealMobile();
		}
	};

	const requestSetup = () => {
		window.cancelAnimationFrame(resizeFrame);
		resizeFrame = window.requestAnimationFrame(setup);
	};

	setup();
	desktopQuery.addEventListener("change", requestSetup);
	window.addEventListener("resize", requestSetup, { passive: true });
</script>

<style>
	.master-class {
		position: relative;
		min-height: 420svh;
		--master-header-offset: clamp(5.8rem, 7.4vw, 7.8rem);
		background: var(--color-background);
		color: var(--color-foreground);
		isolation: isolate;
	}

	.master-class__sticky {
		position: sticky;
		inset-block-start: 0;
		display: grid;
		align-content: start;
		box-sizing: border-box;
		min-height: 100svh;
		padding-block: var(--master-header-offset) clamp(1.2rem, 3vw, 2.4rem);
		overflow: hidden;
	}

	.master-class__content {
		display: grid;
		grid-template-rows: auto auto;
		gap: clamp(1.25rem, 2vw, 2rem);
	}

	.master-class__intro {
		position: relative;
		z-index: 4;
		display: grid;
		gap: clamp(0.52rem, 1.1vw, 0.82rem);
		width: 100%;
		max-width: none;
	}

	.master-class__eyebrow {
		margin: 0;
		color: var(--color-primary-blue);
		font-size: clamp(0.82rem, 1vw, 0.95rem);
		font-weight: 800;
		line-height: 1;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.master-class__title {
		max-width: none;
		margin: 0;
		color: var(--color-foreground);
		font-size: clamp(2.15rem, 5.35vw, 4.9rem);
		font-weight: 800;
		line-height: 0.98;
		letter-spacing: 0;
	}

	.master-class__lead {
		max-width: min(100%, 76rem);
		margin: 0;
		font-size: clamp(1rem, 1.55vw, 1.35rem);
		font-weight: 700;
		line-height: 1.6;
		letter-spacing: 0;
	}

	.master-class__stage {
		position: relative;
		z-index: 2;
		display: grid;
		align-items: start;
		min-height: 0;
	}

	.master-class__deck {
		position: relative;
		z-index: 2;
		display: grid;
		align-items: stretch;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: clamp(0.65rem, 1.15vw, 1rem);
		width: min(100%, 96rem);
		margin-inline: auto;
	}

	.master-card {
		--master-accent: var(--color-green);
		position: relative;
		display: grid;
		grid-template-rows: auto 1fr;
		align-self: stretch;
		justify-self: start;
		width: 100%;
		min-width: 0;
		overflow: hidden;
		border: 0.18rem solid var(--color-foreground);
		border-radius: 0.5rem;
		background: var(--color-background);
		box-shadow: 0.6rem 0.6rem 0 var(--color-foreground);
		transform-origin: center;
		transition:
			width 420ms cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 320ms ease;
		will-change: transform, opacity;
	}

	.master-card--blue {
		--master-accent: var(--color-primary-blue);
	}

	.master-card--orange {
		--master-accent: var(--color-orange);
	}

	.master-card--active {
		width: clamp(26rem, 31vw, 34rem);
		box-shadow: 0.75rem 0.75rem 0 var(--master-accent);
	}

	.master-card--active .master-card__media {
		aspect-ratio: 4 / 3;
	}

	.master-card__media {
		position: relative;
		aspect-ratio: 3 / 4;
		min-height: clamp(12rem, 24svh, 18rem);
		margin: 0;
		overflow: hidden;
		background: var(--color-soft-blue);
		transition: aspect-ratio 420ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.master-card__media::after {
		position: absolute;
		inset: 0;
		content: "";
		background: linear-gradient(180deg, var(--color-transparent) 45%, color-mix(in srgb, var(--color-foreground) 58%, var(--color-transparent)));
		pointer-events: none;
	}

	.master-card__image {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(0.95) contrast(1.04);
		transform: scale(1.07);
		transform-origin: center;
		transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.master-card__body {
		display: grid;
		align-content: start;
		gap: 0.34rem;
		padding: clamp(0.72rem, 1vw, 0.95rem);
		transition:
			gap 320ms ease,
			padding 320ms ease;
	}

	.master-card__kicker,
	.master-card__achievement,
	.master-card__profile {
		margin: 0;
	}

	.master-card__kicker {
		color: var(--master-accent);
		font-size: clamp(1.7rem, 2.55vw, 2.75rem);
		font-weight: 800;
		line-height: 1;
		letter-spacing: 0;
		text-transform: uppercase;
		text-wrap: balance;
		transition:
			font-size 360ms cubic-bezier(0.22, 1, 0.36, 1),
			line-height 360ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.master-card__kicker span {
		display: inline-block;
		white-space: nowrap;
	}

	.master-card__title {
		margin: 0;
		padding-block: clamp(0.08rem, 0.3vw, 0.22rem);
		font-size: clamp(1.02rem, 1.22vw, 1.32rem);
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: 0;
		text-wrap: balance;
		word-break: keep-all;
		transition:
			font-size 360ms cubic-bezier(0.22, 1, 0.36, 1),
			line-height 360ms cubic-bezier(0.22, 1, 0.36, 1),
			padding 360ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.master-card__achievement {
		color: var(--color-dark-green);
		font-size: clamp(0.84rem, 1vw, 1.04rem);
		font-weight: 800;
		line-height: 1.35;
		letter-spacing: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		text-wrap: pretty;
		white-space: nowrap;
		word-break: keep-all;
	}

	.master-card__profile {
		display: grid;
		gap: 0.24rem;
		padding: 0;
		list-style: none;
	}

	.master-card__profile li {
		position: relative;
		padding-inline-start: 0.82rem;
		font-size: clamp(0.78rem, 0.88vw, 0.96rem);
		font-weight: 700;
		line-height: 1.32;
		letter-spacing: 0;
		hyphens: none;
		overflow: hidden;
		text-overflow: ellipsis;
		text-wrap: pretty;
		white-space: nowrap;
	}

	.master-card--active .master-card__body {
		gap: 0.42rem;
		padding: clamp(0.85rem, 1.15vw, 1.08rem);
	}

	.master-card--active .master-card__kicker {
		font-size: clamp(0.95rem, 1vw, 1.1rem);
		line-height: 1.05;
	}

	.master-card--active .master-card__title {
		font-size: clamp(1.72rem, 2.3vw, 2.45rem);
		line-height: 1;
	}

	.master-card--active .master-card__achievement {
		font-size: clamp(1rem, 1.18vw, 1.2rem);
		overflow: visible;
		overflow-wrap: normal;
		text-overflow: clip;
		white-space: normal;
		word-break: keep-all;
		word-break: auto-phrase;
	}

	.master-card--active .master-card__profile {
		gap: 0.32rem;
	}

	.master-card--active .master-card__profile li {
		font-size: clamp(0.9rem, 1vw, 1.02rem);
		line-height: 1.36;
		overflow: visible;
		overflow-wrap: normal;
		text-overflow: clip;
		white-space: normal;
		word-break: keep-all;
		word-break: auto-phrase;
	}

	.master-card__profile li::before {
		position: absolute;
		inset-block-start: 0.5em;
		inset-inline-start: 0;
		width: 0.36rem;
		height: 0.36rem;
		border-radius: 62.4375rem;
		background: var(--master-accent);
		content: "";
	}

	.master-class__details {
		position: absolute;
		inset-block: 0;
		inset-inline-start: clamp(30rem, 52%, 42rem);
		inset-inline-end: 0;
		z-index: 30;
		box-sizing: border-box;
		display: grid;
		align-items: start;
		width: auto;
		pointer-events: none;
	}

	.master-detail {
		--master-accent: var(--color-green);
		grid-area: 1 / 1;
		display: grid;
		gap: clamp(0.8rem, 1.6vw, 1.25rem);
		max-width: 44rem;
		opacity: 0;
		transform: translate3d(0, 0, 0);
		will-change: opacity;
	}

	.master-detail--blue {
		--master-accent: var(--color-primary-blue);
	}

	.master-detail--orange {
		--master-accent: var(--color-orange);
	}

	.master-detail__title,
	.master-detail__summary,
	.master-detail__outcome {
		margin: 0;
	}

	.master-detail__title {
		color: var(--master-accent);
		font-size: clamp(1.35rem, 2.1vw, 1.85rem);
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: 0;
	}

	.master-detail__summary {
		font-size: clamp(1.55rem, 2.8vw, 2.35rem);
		font-weight: 800;
		line-height: 1.28;
		letter-spacing: 0;
	}

	.master-detail__summary span {
		display: block;
	}

	.master-detail__outcome {
		padding-block-start: clamp(0.85rem, 1.6vw, 1.2rem);
		border-block-start: 0.16rem solid var(--color-foreground);
		font-size: clamp(1rem, 1.35vw, 1.22rem);
		font-weight: 700;
		line-height: 1.65;
		letter-spacing: 0;
	}

	@media (max-width: 72rem), (max-height: 44rem) {
		.master-class {
			min-height: auto;
		}

		.master-class__sticky {
			position: relative;
			display: grid;
			min-height: auto;
			padding-block: var(--master-header-offset) clamp(3rem, 8vw, 5rem);
			overflow: visible;
		}

		.master-class__content {
			gap: clamp(1.75rem, 4vw, 2.5rem);
		}

		.master-class__intro {
			max-width: none;
			transform: none;
		}

		.master-class__stage {
			display: grid;
			gap: clamp(1.5rem, 3vw, 2rem);
		}

		.master-class__details {
			position: relative;
			inset: auto;

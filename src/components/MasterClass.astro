---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import IcRoundChevronRight from "~icons/ic/round-chevron-right";
import homeData from "@/data/home.json";

const { masterClassSection, masterClasses } = homeData;

type MasterClassItem = (typeof masterClasses)[number];
type MasterClassGroup = MasterClassItem & {
	speakers: MasterClassItem[];
};

const masterClassGroupFields = ["kicker", "accent", "summary", "outcome", "duration"] as const;
const getMasterClassGroupField = (masterClass: MasterClassItem | MasterClassGroup, field: (typeof masterClassGroupFields)[number]) => (masterClass as Record<string, unknown>)[field];
const serializeMasterClassGroupField = (value: unknown) => JSON.stringify(value);

const groupedMasterClasses = masterClasses.reduce<MasterClassGroup[]>((groups, masterClass) => {
	const existingGroup = groups.find(group => group.title === masterClass.title);

	if (existingGroup) {
		const mismatchedField = masterClassGroupFields.find(
			field => serializeMasterClassGroupField(getMasterClassGroupField(existingGroup, field)) !== serializeMasterClassGroupField(getMasterClassGroupField(masterClass, field))
		);

		if (mismatchedField) {
			throw new Error(`MasterClassGroup/title "${masterClass.title}" has mismatched "${mismatchedField}" content; refusing to merge speakers because course-level copy would be dropped.`);
		}

		existingGroup.speakers.push(masterClass);
		return groups;
	}

	groups.push({
		...masterClass,
		speakers: [masterClass]
	});

	return groups;
}, []);

const visibleMasterClasses = groupedMasterClasses.slice(0, 3);

const topicImagePositions: Record<string, string> = {
	"denny-huang": "54% 44%",
	"jasper-yu": "63% 43%",
	"ak-kuo": "58% 40%",
	"harry-chang": "52% 40%"
};

const masterImages = Object.fromEntries(
	Object.entries(
		import.meta.glob<{ default: ImageMetadata }>("../assets/master-class-speakers/*.{avif,jpeg,jpg,png,webp}", {
			eager: true
		})
	).map(([path, image]) => {
		const key = path
			.split("/")
			.pop()
			?.replace(/\.[^.]+$/, "");
		return [key, image.default];
	})
) as Record<string, ImageMetadata>;

const getMasterImage = (masterClass: MasterClassItem) => {
	const image = masterImages[masterClass.imageKey];

	if (!image) {
		throw new Error(`Missing master class speaker image: ${masterClass.imageKey}`);
	}

	return image;
};
---

<section id="master-class" class="master-class" aria-labelledby="master-class-title">
	<div class="master-class__content site-container">
		<div class="master-class__overview">
			<div class="master-class__intro">
				<p class="master-class__eyebrow">{masterClassSection.eyebrow}</p>
				<h2 id="master-class-title" class="master-class__title">{masterClassSection.title}</h2>
				<p class="master-class__lead">{masterClassSection.lead}</p>
			</div>
		</div>

		<div class="master-carousel" aria-label="主題講師與課程介紹" data-master-carousel>
			<div class="master-carousel__viewport">
				<div class="master-carousel__track" data-master-carousel-track>
					<div class="master-carousel__slide master-carousel__slide--topics" data-master-carousel-slide aria-hidden="false">
						<div class="master-class__topics" aria-label={masterClassSection.deckAriaLabel}>
							{
								visibleMasterClasses.map(masterClass => {
									return (
										<article class:list={["topic-card", `topic-card--${masterClass.accent}`]}>
											<figure class:list={["topic-card__media", { "topic-card__media--duo": masterClass.speakers.length > 1 }]}>
												{masterClass.speakers.map(speaker => {
													const image = getMasterImage(speaker);
													const topicImagePosition = topicImagePositions[speaker.imageKey] ?? speaker.imagePosition;

													return (
														<div class="topic-card__portrait">
															<Image
																src={image}
																alt={`${masterClass.title} ${speaker.instructor} 講師照片`}
																class="topic-card__image"
																loading="lazy"
																decoding="async"
																format="webp"
																style={`object-position: ${topicImagePosition}`}
															/>
														</div>
													);
												})}
											</figure>
											<div class="topic-card__body">
												<h3 class="topic-card__title">{masterClass.title}</h3>
												<div class:list={["topic-card__speaker-list", { "topic-card__speaker-list--multiple": masterClass.speakers.length > 1 }]}>
													{masterClass.speakers.map(speaker => (
														<div class="topic-card__speaker">
															<p class="topic-card__instructor">{speaker.instructor}</p>
															<p class="topic-card__achievement">{speaker.achievement}</p>
															{masterClass.speakers.length === 1 && (
																<ul class="topic-card__profile" aria-label={`${speaker.instructor} 講師履歷亮點`}>
																	{speaker.profile.map(item => (
																		<li>{item}</li>
																	))}
																</ul>
															)}
														</div>
													))}
												</div>
											</div>
										</article>
									);
								})
							}
						</div>
					</div>
					{
						visibleMasterClasses.map(masterClass => {
							return (
								<article class:list={["master-carousel__slide", "course-slide", `course-slide--${masterClass.accent}`]} data-master-carousel-slide aria-hidden="true">
									<figure class:list={["course-slide__media", { "course-slide__media--duo": masterClass.speakers.length > 1 }]}>
										{masterClass.speakers.map(speaker => {
											const image = getMasterImage(speaker);
											const isCustomSizedPortrait = speaker.imageKey === "ak-kuo";
											const courseImagePosition = isCustomSizedPortrait ? "center center" : speaker.imagePosition;
											const courseImageClass = isCustomSizedPortrait ? "course-slide__image course-slide__image--custom-size" : "course-slide__image";

											return (
												<div class:list={["course-slide__portrait", { "course-slide__portrait--custom-size": isCustomSizedPortrait }]}>
													{isCustomSizedPortrait && (
														<Image
															src={image}
															alt=""
															aria-hidden="true"
															class="course-slide__image course-slide__image--backdrop"
															loading="lazy"
															decoding="async"
															format="webp"
															style={`object-position: ${courseImagePosition}`}
														/>
													)}
													<Image
														src={image}
														alt={`${masterClass.title} ${speaker.instructor} 講師照片`}
														class={courseImageClass}
														loading="lazy"
														decoding="async"
														format="webp"
														style={`object-position: ${courseImagePosition}`}
													/>
												</div>
											);
										})}
									</figure>

									<div class="course-slide__content">
										<div class="course-slide__course">
											<h3 class="course-slide__title">{masterClass.title}</h3>
											<p class="course-slide__summary">
												{masterClass.summary.map(item => (
													<span class="course-slide__summary-line">{item}</span>
												))}
											</p>
											<p class="course-slide__outcome">{masterClass.outcome}</p>
										</div>

										<div class:list={["course-slide__speaker", { "course-slide__speaker--multiple": masterClass.speakers.length > 1 }]}>
											<p class="course-slide__speaker-label">{masterClass.speakers.length > 1 ? "講師陣容" : "講師"}</p>
											<div class="course-slide__speaker-list">
												{masterClass.speakers.map(speaker => (
													<div class="course-slide__speaker-card">
														<h3 class="course-slide__instructor">{speaker.instructor}</h3>
														<p class="course-slide__achievement">{speaker.achievement}</p>
														<ul class="course-slide__profile" aria-label={`${speaker.instructor} 講師履歷亮點`}>
															{speaker.profile.map(item => (
																<li>{item}</li>
															))}
														</ul>
													</div>
												))}
											</div>
										</div>
									</div>
								</article>
							);
						})
					}
				</div>
			</div>

			<div class="master-carousel__controls">
				<div class="master-carousel__tabs" role="tablist" aria-label="選擇主題">
					<span class="master-carousel__tab-indicator" data-master-carousel-tab-indicator aria-hidden="true"></span>
					<button
						class:list={["master-carousel__tab", "master-carousel__tab--active"]}
						type="button"
						role="tab"
						aria-label="顯示講師總覽"
						aria-selected="true"
						data-master-carousel-tab
						data-master-carousel-index={0}
					>
						三大課程
					</button>
					{
						visibleMasterClasses.map((masterClass, index) => (
							<button
								class="master-carousel__tab"
								type="button"
								role="tab"
								aria-label={`顯示${masterClass.title}`}
								aria-selected="false"
								data-master-carousel-tab
								data-master-carousel-index={index + 1}
							>
								{masterClass.title}
							</button>
						))
					}
				</div>
				<a class="master-carousel__schedule-link" href={masterClassSection.scheduleLink.href}>
					<span class="master-carousel__schedule-link-label">{masterClassSection.scheduleLink.label}</span>
					<IcRoundChevronRight class="master-carousel__schedule-link-icon" aria-hidden="true" />
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	document.addEventListener("astro:page-load", () => {
		const ac = new AbortController();
		const { signal } = ac;
		document.addEventListener("astro:before-swap", () => ac.abort(), { once: true });

		const carousel = document.querySelector<HTMLElement>("[data-master-carousel]");

		if (carousel) {
			const viewport = carousel.querySelector<HTMLElement>(".master-carousel__viewport");
			const slides = Array.from(carousel.querySelectorAll<HTMLElement>("[data-master-carousel-slide]"));
			const tabs = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-master-carousel-tab]"));
			const tabIndicator = carousel.querySelector<HTMLElement>("[data-master-carousel-tab-indicator]");
			let activeIndex = 0;
			let scrollFrame = 0;
			let scrollEndTimeout = 0;
			let isProgrammaticScroll = false;
			let pointerStartX = 0;
			let didDrag = false;
			let viewportHeightFrame = 0;

			const updateViewportHeight = () => {
				if (!viewport) {
					return;
				}

				const activeSlide = slides[activeIndex];

				if (!activeSlide) {
					return;
				}

				viewport.style.setProperty("--master-carousel-active-height", `${Math.ceil(activeSlide.getBoundingClientRect().height)}px`);
			};

			const queueViewportHeightUpdate = () => {
				window.cancelAnimationFrame(viewportHeightFrame);
				viewportHeightFrame = window.requestAnimationFrame(updateViewportHeight);
			};

			const updateTabIndicator = () => {
				const activeTab = tabs[activeIndex];

				if (!tabIndicator || !activeTab) {
					return;
				}

				tabIndicator.style.width = `${activeTab.offsetWidth}px`;
				tabIndicator.style.transform = `translate3d(${activeTab.offsetLeft}px, 0, 0)`;
			};

			const updateActiveState = (index: number) => {
				if (slides.length === 0) {
					return;
				}

				activeIndex = (index + slides.length) % slides.length;

				slides.forEach((slide, slideIndex) => {
					slide.setAttribute("aria-hidden", String(slideIndex !== activeIndex));
					slide.classList.toggle("master-carousel__slide--active", slideIndex === activeIndex);
				});

				tabs.forEach((tab, tabIndex) => {
					const isActive = tabIndex === activeIndex;
					tab.classList.toggle("master-carousel__tab--active", isActive);
					tab.setAttribute("aria-selected", String(isActive));
				});

				updateTabIndicator();
				queueViewportHeightUpdate();
			};

			const getSlideScrollLeft = (slide: HTMLElement) => {
				if (!viewport) {
					return 0;
				}

				const viewportRect = viewport.getBoundingClientRect();
				const slideRect = slide.getBoundingClientRect();

				return viewport.scrollLeft + slideRect.left + slideRect.width / 2 - (viewportRect.left + viewportRect.width / 2);
			};

			const setActiveSlide = (index: number, shouldScroll = true, behavior: ScrollBehavior = "smooth") => {
				if (!viewport || slides.length === 0) {
					return;
				}

				updateActiveState(index);

				if (shouldScroll) {
					isProgrammaticScroll = true;
					viewport.scrollTo({
						left: getSlideScrollLeft(slides[activeIndex]),
						behavior
					});
					window.clearTimeout(scrollEndTimeout);
					scrollEndTimeout = window.setTimeout(() => {
						isProgrammaticScroll = false;
						syncActiveFromScroll();
					}, 620);
				}
			};

			const syncActiveFromScroll = () => {
				if (!viewport || slides.length === 0) {
					return;
				}

				const viewportRect = viewport.getBoundingClientRect();
				const viewportCenter = viewportRect.left + viewportRect.width / 2;
				const nearestIndex = slides.reduce((nearest, slide, slideIndex) => {
					const currentRect = slides[nearest].getBoundingClientRect();
					const nextRect = slide.getBoundingClientRect();
					const currentCenter = currentRect.left + currentRect.width / 2;
					const nextCenter = nextRect.left + nextRect.width / 2;
					const currentDistance = Math.abs(currentCenter - viewportCenter);
					const nextDistance = Math.abs(nextCenter - viewportCenter);
					return nextDistance < currentDistance ? slideIndex : nearest;
				}, 0);

				updateActiveState(nearestIndex);
			};

			tabs.forEach(tab => {
				tab.addEventListener("click", () => {
					setActiveSlide(Number(tab.dataset.masterCarouselIndex ?? 0));
				});
			});

			slides.forEach((slide, slideIndex) => {
				slide.addEventListener("click", () => {
					if (didDrag || slideIndex === activeIndex) {
						return;
					}

					setActiveSlide(slideIndex);
				});
			});

			const slideResizeObserver = "ResizeObserver" in window ? new ResizeObserver(queueViewportHeightUpdate) : null;
			slides.forEach(slide => slideResizeObserver?.observe(slide));
			signal.addEventListener("abort", () => slideResizeObserver?.disconnect());
			window.addEventListener("resize", queueViewportHeightUpdate, { signal });

			viewport?.addEventListener(
				"scroll",
				() => {
					if (isProgrammaticScroll) {
						return;
					}

					window.cancelAnimationFrame(scrollFrame);
					scrollFrame = window.requestAnimationFrame(syncActiveFromScroll);
				},
				{ passive: true }
			);

			viewport?.addEventListener("pointerdown", event => {
				pointerStartX = event.clientX;
				didDrag = false;
			});

			viewport?.addEventListener("pointermove", event => {
				if (Math.abs(event.clientX - pointerStartX) > 8) {
					didDrag = true;
				}
			});

			window.addEventListener(
				"resize",
				() => {
					setActiveSlide(activeIndex, true, "auto");
					updateTabIndicator();
				},
				{ signal }
			);

			carousel.addEventListener("keydown", event => {
				if (event.key === "ArrowLeft") {
					event.preventDefault();
					setActiveSlide(activeIndex - 1);
				}

				if (event.key === "ArrowRight") {
					event.preventDefault();
					setActiveSlide(activeIndex + 1);
				}
			});

			setActiveSlide(0, true, "auto");
		}
	});
</script>

<style>
	.master-class {
		--master-controls-offset: clamp(0.75rem, 2vw, 1.25rem);
		--master-controls-reserved: 0.9rem;
		position: relative;
		padding-block: 0 clamp(4.5rem, 9vw, 8rem);
		scroll-margin-block-start: calc(5.5rem + env(safe-area-inset-top, 0px));
		background: var(--color-background);
		color: var(--color-foreground);
		isolation: isolate;
	}

	.master-class__content {
		display: grid;
		gap: clamp(2rem, 3.8vw, 3.5rem);
	}

	.master-class__overview {
		display: grid;
		gap: clamp(1.75rem, 3vw, 3rem);
	}

	.master-class__intro {
		display: grid;
		gap: clamp(0.52rem, 1.1vw, 0.82rem);
		width: 100%;
		max-width: none;
	}

	.master-class__eyebrow {
		margin: 0;
		color: var(--color-primary-blue);
		font-size: clamp(0.82rem, 1vw, 0.95rem);
		font-weight: 800;
		line-height: 1;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.master-class__title {
		max-width: none;
		margin: 0;
		color: var(--color-foreground);
		font-size: clamp(2.15rem, 5.35vw, 4.9rem);
		font-weight: 800;
		line-height: 0.98;
		letter-spacing: 0;
	}

	.master-class__lead {
		max-width: min(100%, 76rem);
		margin: 0;
		font-size: clamp(1rem, 1.55vw, 1.35rem);
		font-weight: 700;
		line-height: 1.6;
		letter-spacing: 0;
	}

	.master-class__topics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(0.8rem, 1.3vw, 1.2rem);
	}

	.topic-card {
		--master-accent: var(--color-green);
		display: grid;
		grid-template-rows: auto 1fr;
		overflow: hidden;
		border: 0.18rem solid var(--color-foreground);
		border-radius: 0.5rem;
		background: var(--color-background);
		box-shadow: 0.6rem 0.6rem 0 var(--color-foreground);
	}

	.course-slide--green {
		--master-accent: var(--color-green);
	}

	.topic-card--blue,
	.course-slide--blue {
		--master-accent: var(--color-primary-blue);
	}

	.topic-card--orange,
	.course-slide--orange {
		--master-accent: var(--color-orange);
	}

	.topic-card__media {
		position: relative;
		display: grid;
		box-sizing: border-box;
		inline-size: 100%;
		aspect-ratio: 4 / 3;
		margin: 0;
		overflow: hidden;
		background: var(--color-soft-blue);
	}

	.topic-card__media--duo {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.topic-card__media::after {
		position: absolute;
		inset: 0;
		content: "";
		background: linear-gradient(180deg, var(--color-transparent) 50%, color-mix(in srgb, var(--color-foreground) 24%, var(--color-transparent)));
		pointer-events: none;
	}

	.topic-card__portrait {
		position: relative;
		min-width: 0;
		min-height: 0;
		overflow: hidden;
	}

	.topic-card__media--duo .topic-card__portrait + .topic-card__portrait {
		border-inline-start: 0.14rem solid var(--color-foreground);
	}

	.topic-card__image {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(0.95) contrast(1.04);
		transform: scale(1.04);
	}

	.topic-card__body {
		display: grid;
		align-content: start;
		gap: clamp(0.34rem, 0.8vw, 0.58rem);
		padding: clamp(0.95rem, 1.5vw, 1.3rem);
	}

	.topic-card__speaker-list,
	.topic-card__instructor,
	.topic-card__achievement,
	.topic-card__profile {
		margin: 0;
	}

	.topic-card__speaker-list,
	.topic-card__speaker {
		display: grid;
		gap: clamp(0.3rem, 0.65vw, 0.5rem);
	}

	.topic-card__speaker-list--multiple {
		gap: clamp(0.58rem, 0.95vw, 0.75rem);
	}

	.topic-card__speaker-list--multiple .topic-card__speaker + .topic-card__speaker {
		padding-block-start: clamp(0.58rem, 0.95vw, 0.75rem);
		border-block-start: 0.12rem solid var(--color-foreground);
	}

	.topic-card__title {
		margin: 0;
		padding-block: clamp(0.22rem, 0.7vw, 0.58rem);
		color: var(--master-accent);
		font-size: clamp(2.2rem, 4.4vw, 4.65rem);
		font-weight: 800;
		line-height: 0.95;
		letter-spacing: 0;
		text-wrap: balance;
		word-break: keep-all;
	}

	.topic-card__instructor {
		font-size: clamp(1.15rem, 1.55vw, 1.45rem);
		font-weight: 800;
		line-height: 1.08;
		letter-spacing: 0;
		text-wrap: balance;
		word-break: keep-all;
	}

	.topic-card__achievement {
		color: var(--color-dark-green);
		font-size: clamp(0.98rem, 1.22vw, 1.2rem);
		font-weight: 800;
		line-height: 1.35;
		letter-spacing: 0;
		text-wrap: auto;
		word-break: auto-phrase;
	}

	.topic-card__profile {
		display: grid;
		gap: 0.3rem;
		padding: 0;
		list-style: none;
	}

	.topic-card__profile li {
		position: relative;
		padding-inline-start: 0.82rem;
		font-size: clamp(0.9rem, 1.03vw, 1.04rem);
		font-weight: 700;
		line-height: 1.36;
		letter-spacing: 0;
		text-wrap: pretty;
		word-break: keep-all;
		overflow-wrap: anywhere;
	}

	.topic-card__profile li::before {
		position: absolute;
		inset-block-start: 0.5em;
		inset-inline-start: 0;
		width: 0.36rem;
		height: 0.36rem;
		border-radius: 62.4375rem;
		background: var(--master-accent);
		content: "";
	}

	.master-carousel {
		--carousel-gap: clamp(1rem, 2.4vw, 2rem);
		--carousel-slide-width: min(calc(100vw - var(--site-content-gutter) * 2), var(--site-content-max));
		--carousel-side-space: max(var(--site-content-gutter), calc((100vw - var(--carousel-slide-width)) / 2));
		--carousel-control-offset: clamp(0.75rem, 2vw, 1.25rem);
		--carousel-control-clearance: calc(4.35rem + var(--carousel-control-offset) + env(safe-area-inset-bottom, 0px));
		min-width: 0;
		width: 100vw;
		margin-inline: calc(50% - 50vw);
		display: grid;
		gap: clamp(1rem, 2vw, 1.5rem);
	}

	.master-carousel__viewport {
		box-sizing: content-box;
		min-width: 0;
		max-width: 100%;
		overflow-x: auto;
		overflow-y: visible;
		padding-block: 0.2rem var(--master-controls-reserved);
		cursor: grab;
		scroll-padding-inline: var(--carousel-side-space);
		scroll-snap-type: x mandatory;
		scrollbar-width: none;
		touch-action: pan-x pan-y;
		-webkit-overflow-scrolling: touch;
	}

	.master-carousel__viewport:active {
		cursor: grabbing;

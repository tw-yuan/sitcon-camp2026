<style>
  @reference "../styles/global.css";

  .stat-card {
    @apply rounded-2xl bg-green text-dark-green flex flex-col items-center justify-center gap-1 shadow-sm transition-shadow duration-300 hover:shadow-md cursor-pointer;
  }
  .hover-overlay {
    @apply absolute inset-0 p-3 flex items-end justify-start bg-black/30 opacity-0 transition-opacity duration-300;
  }
  .group:hover .hover-overlay {
    @apply opacity-100;
  }
  .card-img {
    @apply relative flex items-end overflow-hidden rounded-2xl p-6 text-white shadow-sm transition-shadow duration-300 hover:shadow-md cursor-pointer;
  }
  .media-card {
    @apply relative flex items-center justify-center overflow-hidden rounded-2xl p-6 text-white shadow-sm transition-shadow duration-300 hover:shadow-md cursor-pointer;
  }
</style>


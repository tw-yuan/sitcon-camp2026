---
import { Image } from "astro:assets";
import camp from "../assets/pics/camp.webp";
import groups from "../assets/pics/groups.webp";
import hackathon from "../assets/pics/hackathon.webp";
import edu from "../assets/pics/edu.webp";
import ettodayNews from "../assets/pics/ettodayNews.webp";
import moneyUdnNews from "../assets/pics/moneyUdnNews.webp";
import youratorNews from "../assets/pics/youratorNews.webp";
import yahooNews from "../assets/pics/yahooNews.webp";
---

<style>
  @reference "../styles/global.css";

  .stat-card {
    @apply bg-green text-dark-green flex cursor-pointer flex-col items-center justify-center gap-1 rounded-2xl shadow-sm transition-shadow duration-300 hover:shadow-md;
  }
  .hover-overlay {
    @apply absolute inset-0 flex items-end justify-start bg-black/30 p-3 opacity-0 transition-opacity duration-300;
  }
  .group:hover .hover-overlay {
    @apply opacity-100;
  }
  .card-img {
    @apply relative flex aspect-[5/2] cursor-pointer items-end overflow-hidden rounded-2xl p-6 text-white shadow-sm transition-shadow duration-300 hover:shadow-md;
  }
  .media-card {
    @apply relative flex aspect-[3/2] cursor-pointer items-center justify-center overflow-hidden rounded-2xl p-6 text-white shadow-sm transition-shadow duration-300 hover:shadow-md;
  }
</style>

<main class="bg-background text-foreground">
  <section class="mx-auto max-w-6xl px-4 py-6 md:px-6 md:py-10 lg:px-8">
    <img class="w-full rounded-2xl object-cover" alt="" />
    <div class="mt-6 md:mt-8">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">關於 SITCON</h2>
      <p class="text-foreground/70 mt-3 max-w-4xl text-sm/6 md:text-base/7">
        ...
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-14 lg:px-8">
    <h3 class="text-center text-2xl font-bold tracking-tight md:text-4xl">
      13 年來...
    </h3>
    <div class="mt-8 grid auto-rows-[140px] grid-cols-1 gap-5 md:grid-cols-6">
      <article class="stat-card group md:col-span-2">
        <span class="text-3xl font-extrabold md:text-4xl">500+</span>
        <span class="text-sm/4 font-medium opacity-75">參與者</span>
      </article>
      <article class="stat-card group md:col-span-2">
        <span class="text-3xl font-extrabold md:text-4xl">500+</span>
        <span class="text-sm/4 font-medium opacity-75">議程</span>
      </article>
      <article class="stat-card group md:col-span-2">
        <span class="text-3xl font-extrabold md:text-4xl">10+</span>
        <span class="text-sm/4 font-medium opacity-75">工作坊</span>
      </article>
      <article class="stat-card md:col-span-3">
        <span class="text-3xl font-extrabold md:text-4xl">14,000+</span>
        <span class="text-sm/4 font-medium opacity-75">累積參與人次</span>
      </article>
      <article class="stat-card md:col-span-3">
        <span class="text-3xl font-extrabold md:text-4xl">1,400+</span>
        <span class="text-sm/4 font-medium opacity-75">志工貢獻</span>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-14 lg:px-8">
    <h3 class="text-center text-2xl font-bold tracking-tight md:text-4xl">
      我們做過的事
    </h3>
    <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2">
      <article class="card-img group">
        <Image
          src={groups}
          alt="年會"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">年會</h1>
        </div>
      </article>
      <article class="card-img group">
        <Image
          src={groups}
          alt="跨校交流"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">跨校交流</h1>
        </div>
      </article>
      <article class="card-img group">
        <Image
          src={edu}
          alt="edu"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">edu</h1>
        </div>
      </article>
      <article class="card-img group">
        <Image
          src={hackathon}
          alt="黑客松"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">黑客松</h1>
        </div>
      </article>
      <article class="card-img group md:col-span-2" style="aspect-ratio: 16/5;">
        <Image
          src={camp}
          alt="黑客松"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">更多活動...</h1>
        </div>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-14 lg:px-8">
    <h3 class="text-center text-2xl font-bold tracking-tight md:text-4xl">
      媒體報導
    </h3>
    <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-4">
      <article class="media-card group">
        <Image
          src={yahooNews}
          alt="Yahoo 新聞"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">Yahoo 新聞</h1>
        </div>
      </article>
      <article class="media-card group">
        <Image
          src={ettodayNews}
          alt="ETtoday 新聞"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">ETtoday 新聞</h1>
        </div>
      </article>
      <article class="media-card group">
        <Image
          src={moneyUdnNews}
          alt="Money UDN 新聞"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">Money UDN 新聞</h1>
        </div>
      </article>
      <article class="media-card group">
        <Image
          src={youratorNews}
          alt="Yourator 新聞"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="hover-overlay">
          <h1 class="text-lg font-bold">Yourator 新聞</h1>
        </div>
      </article>
    </div>
  </section>
</main>

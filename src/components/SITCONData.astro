---
import siteContent from "@/data/site.json";
import LucideCircleArrowUp from "~icons/lucide/circle-arrow-up";
import LucideCircleArrowDown from "~icons/lucide/circle-arrow-down";

const { sitconData } = siteContent;

const data = sitconData.datas;
const first = data[0];
---

<!-- data-scroll-counter 作為穩定的 JS 選取點 -->
<div data-scroll-counter style={`height: ${scrollHeight}vh`} class="relative">
	<div
		class="sticky top-0 grid h-screen [grid-template-columns:1fr_auto_1fr] items-center gap-8 overflow-hidden bg-[#0a0a0f] px-[5vw] max-sm:[grid-template-columns:1fr] max-sm:[grid-template-rows:auto_auto_auto] max-sm:justify-items-center max-sm:gap-6 max-sm:px-6"
	>
		<!-- 進度條 -->
		<div class="absolute top-0 right-0 left-0 z-10 h-0.5 bg-[#1e1e2e]">
			<div data-progress-fill class="h-full w-0 bg-gradient-to-r from-[#7eb8c9] to-[#e8d5a3] transition-[width] duration-[50ms] [transition-timing-function:linear]"></div>
		</div>

		<!-- 左側文字軌道 -->
		<div class="relative z-[5] h-10 overflow-hidden text-right max-sm:text-center">
			<div data-prefix-track class="flex flex-col transition-transform duration-[550ms] [transition-timing-function:cubic-bezier(0.4,0,0.2,1)] will-change-transform">
				{data.map(d => <div class="flex h-10 items-center justify-end text-[clamp(1rem,2vw,1.4rem)] leading-none whitespace-nowrap text-[#e8d5a3] max-sm:justify-center">{d.prefix}</div>)}
			</div>
		</div>

		<!-- 中央數字 -->
		<div class="relative z-[5] flex min-w-72 flex-col items-center gap-2">
			<!-- 垂直裝飾線 -->
			<div
				class="pointer-events-none absolute top-1/2 left-1/2 -z-[1] [height:calc(100%+3rem)] w-px -translate-x-1/2 -translate-y-1/2 [background:linear-gradient(to_bottom,transparent,#3a3a52_30%,#3a3a52_70%,transparent)]"
			>
			</div>
			<div data-number class="text-[clamp(3.5rem,10vw,7rem)] leading-none font-bold tracking-[-0.03em] text-white tabular-nums max-sm:text-[4.5rem]">
				{first.value.toLocaleString()}
			</div>
			<div class="my-0.5 h-px w-full [background:linear-gradient(90deg,transparent,#3a3a52,transparent)]"></div>
		</div>

		<!-- 右側文字軌道 -->
		<div class="relative z-[5] h-10 overflow-hidden text-left max-sm:text-center">
			<div data-suffix-track class="flex flex-col transition-transform duration-[550ms] [transition-timing-function:cubic-bezier(0.4,0,0.2,1)] will-change-transform">
				{data.map(d => <div class="flex h-10 items-center justify-start text-[clamp(1rem,2vw,1.4rem)] leading-none whitespace-nowrap text-[#e8d5a3] max-sm:justify-center">{d.suffix}</div>)}
			</div>
		</div>

		<!-- 導航箭頭 -->
		<button
			data-btn-prev
			class="absolute right-[5vw] bottom-[calc(50%+2.8rem)] z-10 flex h-8 w-8 cursor-pointer items-center justify-center rounded border border-[#3a3a52] bg-transparent text-sm text-[#555570] transition-[border-color,color] duration-200 enabled:hover:border-[#e8d5a3] enabled:hover:text-[#e8d5a3] disabled:cursor-default disabled:opacity-20"
			aria-label="上一個節點"
		>
			&#8593;
		</button>
		<button
			data-btn-next
			class="absolute top-[calc(50%+2.8rem)] right-[5vw] z-10 flex h-8 w-8 cursor-pointer items-center justify-center rounded border border-[#3a3a52] bg-transparent text-sm text-[#555570] transition-[border-color,color] duration-200 enabled:hover:border-[#e8d5a3] enabled:hover:text-[#e8d5a3] disabled:cursor-default disabled:opacity-20"
			aria-label="下一個節點"
		>
			&#8595;
		</button>
	</div>
</div>

<script define:vars={{ data }}>
	function lerp(a, b, t) {
		return a + (b - a) * t;
	}

	function getState(progress) {
		if (progress <= data[0].progress) return { ...data[0], activeIdx: 0 };
		const last = data.length - 1;
		if (progress >= data[last].progress) return { ...data[last], activeIdx: last };

		const nextIdx = data.findIndex(k => k.progress >= progress);
		const prevIdx = nextIdx - 1;
		const prev = data[prevIdx];
		const next = data[nextIdx];
		const t = (progress - prev.progress) / (next.progress - prev.progress);

		return {
			value: lerp(prev.value, next.value, t),
			activeIdx: t > 0.5 ? nextIdx : prevIdx
		};
	}

	document.querySelectorAll("[data-scroll-counter]").forEach(container => {
		const sticky = container.firstElementChild;
		const progressFill = container.querySelector("[data-progress-fill]");
		const numberEl = container.querySelector("[data-number]");
		const prefixTrack = container.querySelector("[data-prefix-track]");
		const suffixTrack = container.querySelector("[data-suffix-track]");
		const btnPrev = container.querySelector("[data-btn-prev]");
		const btnNext = container.querySelector("[data-btn-next]");

		let targetValue = 0;
		let displayedValue = 0;
		let currentProgress = 0;
		let activeIdx = 0;
		let snapTimer = null;
		let lastScrollY = window.scrollY;
		let scrollDir = 1;
		let isSnapping = false;

		function scrollToNode(idx) {
			const clamped = Math.max(0, Math.min(data.length - 1, idx));
			const scrollable = container.offsetHeight - window.innerHeight;
			const offsetTop = container.getBoundingClientRect().top + window.scrollY;
			isSnapping = true;
			window.scrollTo({ top: offsetTop + data[clamped].progress * scrollable, behavior: "smooth" });
			// smooth scroll 沒有完成回呼，用 timeout 等待動畫結束後再解鎖
			clearTimeout(snapTimer);
			snapTimer = setTimeout(() => {
				isSnapping = false;
			}, 700);
		}

		// ── 依滾動方向決定要 snap 到哪個節點 ──────────
		// 向下 → 找第一個 progress >= 當前的節點（前方節點）
		// 向上 → 找最後一個 progress <= 當前的節點（後方節點）
		function snapIdxByDirection() {
			if (scrollDir > 0) {
				const idx = data.findIndex(k => k.progress >= currentProgress);
				return idx === -1 ? data.length - 1 : idx;
			} else {
				let idx = 0;
				for (let i = data.length - 1; i >= 0; i--) {
					if (data[i].progress <= currentProgress) {
						idx = i;
						break;
					}
				}
				return idx;
			}
		}

		btnPrev.addEventListener("click", () => scrollToNode(activeIdx - 1));
		btnNext.addEventListener("click", () => scrollToNode(activeIdx + 1));

		function updateNavState(idx) {
			btnPrev.disabled = idx === 0;
			btnNext.disabled = idx === data.length - 1;
		}

		// ── 文字軌道滑動 ─────────────────────────────
		function slideToIdx(idx) {
			if (activeIdx === idx) return;
			activeIdx = idx;
			// 每個項目高度固定為 h-10 = 2.5rem，用 rem 而非 % 才能正確移動一格
			prefixTrack.style.transform = `translateY(${-(idx * 2.5)}rem)`;
			suffixTrack.style.transform = `translateY(${-(idx * 2.5)}rem)`;
		}

		// ── Scroll handler ───────────────────────────
		function onScroll() {
			scrollDir = window.scrollY >= lastScrollY ? 1 : -1;
			lastScrollY = window.scrollY;

			const rect = container.getBoundingClientRect();
			const scrollable = container.offsetHeight - window.innerHeight;
			currentProgress = Math.max(0, Math.min(1, -rect.top / scrollable));

			const state = getState(currentProgress);
			targetValue = Math.round(state.value);
			updateNavState(state.activeIdx);
			progressFill.style.width = currentProgress * 100 + "%";

			// 只有在元件的滾動範圍內（sticky 生效中）才吸附
			// rect.top <= 0 且 rect.bottom >= innerHeight 代表 sticky 正在作用
			const isActive = rect.top <= 0 && rect.bottom >= window.innerHeight;
			if (isActive && !isSnapping) {
				clearTimeout(snapTimer);
				snapTimer = setTimeout(() => scrollToNode(snapIdxByDirection()), 150);
			}
		}

		// ── rAF 主循環：chasing counter ──────────────
		// 文字軌道也在這裡更新，確保永遠與顯示的數字同步
		function tick() {
			requestAnimationFrame(tick);

			if (displayedValue !== targetValue) {
				const diff = targetValue - displayedValue;
				const step = Math.sign(diff) * Math.max(1, Math.floor(Math.abs(diff) * 0.12));
				displayedValue += step;
				if (diff > 0 && displayedValue > targetValue) displayedValue = targetValue;
				if (diff < 0 && displayedValue < targetValue) displayedValue = targetValue;
				numberEl.textContent = displayedValue.toLocaleString();
			}

			// 找到 displayedValue 最接近的節點，滑動文字軌道
			let closestIdx = 0;
			let minDist = Infinity;
			data.forEach((d, i) => {
				const dist = Math.abs(d.value - displayedValue);
				if (dist < minDist) {
					minDist = dist;
					closestIdx = i;
				}
			});
			slideToIdx(closestIdx);
		}

		window.addEventListener("scroll", onScroll, { passive: true });
		onScroll();
		tick();
	});
</script>

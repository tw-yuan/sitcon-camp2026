---
import SchedulePreview from "@/components/SchedulePreview.astro";
import { scheduleMeta } from "@/data/schedule";
import layoutData from "@/data/layout.json";
import Layout from "@/layouts/Layout.astro";

const siteURL = Astro.site ?? new URL("https://sitcon.camp");
const homeURL = new URL("/2026/", siteURL);
const scheduleURL = new URL("/2026/schedule/", siteURL);

const schedulePageSchema = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: scheduleMeta.title,
	description: scheduleMeta.description,
	url: scheduleURL.href,
	inLanguage: layoutData.document.lang,
	isPartOf: {
		"@type": "WebSite",
		name: layoutData.document.brandName,
		url: homeURL.href
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: "SITCON 夏令營 2026",
			item: homeURL.href
		},
		{
			"@type": "ListItem",
			position: 2,
			name: "活動日程",
			item: scheduleURL.href
		}
	]
};

const structuredData = [schedulePageSchema, breadcrumbSchema];
---

<Layout title={`${scheduleMeta.title}｜SITCON 夏令營 2026`} description={scheduleMeta.description} additionalStructuredData={structuredData}>
	<SchedulePreview />
</Layout>

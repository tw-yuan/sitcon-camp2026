  <script>
    import Hls from "hls.js";
    import initLandingAnimations from "../scripts/landing-animations";

    initLandingAnimations();

    const heroVideo =
      document.querySelector<HTMLVideoElement>("[data-hero-video]");

    if (heroVideo) {
      let hasLoadedVideo = false;
      let hls: Hls | undefined;
      const videoSource = heroVideo.dataset.videoSrc;
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const connection = (navigator as Navigator & {
        connection?: { saveData?: boolean };
      }).connection;

      const showHeroVideo = () => {
        heroVideo.classList.add("is-ready");
      };

      const playHeroVideo = () => {
        void heroVideo.play().catch(() => {
          heroVideo.classList.remove("is-ready");
        });
      };

      const loadHeroVideo = () => {
        if (
          hasLoadedVideo ||
          !videoSource ||
          prefersReducedMotion ||
          connection?.saveData
        ) {
          return;
        }

        hasLoadedVideo = true;

        if (heroVideo.canPlayType("application/vnd.apple.mpegurl")) {
          heroVideo.src = videoSource;
          heroVideo.load();
          playHeroVideo();
          return;
        }

        if (!Hls.isSupported()) {
          return;
        }

        hls = new Hls();
        hls.loadSource(videoSource);
        hls.attachMedia(heroVideo);
        hls.on(Hls.Events.MANIFEST_PARSED, playHeroVideo);
        hls.on(Hls.Events.ERROR, (_event, data) => {
          if (data.fatal) {
            heroVideo.classList.remove("is-ready");
            hls?.destroy();
            hls = undefined;
          }
        });
      };

      heroVideo.addEventListener("canplay", showHeroVideo, { once: true });
      heroVideo.addEventListener("playing", showHeroVideo, { once: true });
      heroVideo.addEventListener("error", () => {
        heroVideo.classList.remove("is-ready");
      });
      window.addEventListener("pagehide", () => hls?.destroy(), {
        once: true,
      });

      const loadOnInteraction = () => {
        loadHeroVideo();
      };

      window.addEventListener("pointerdown", loadOnInteraction, {
        once: true,
        passive: true,
      });
      window.addEventListener("keydown", loadOnInteraction, { once: true });

      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(loadHeroVideo, { timeout: 2500 });
      } else {
        window.setTimeout(loadHeroVideo, 1600);
      }
    }
  </script>

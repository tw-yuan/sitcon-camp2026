---
import Hero from "@/components/Hero.astro";
import Layout from "../layouts/Layout.astro";
import BrandMarquee from "@/components/BrandMarquee.astro";
import MasterClass from "@/components/MasterClass.astro";
import MasterCarousel from "@/components/MasterCarousel.astro";
import AboutSitconCamp from "@/components/AboutSitconCamp.astro";
import StudentComment from "@/components/StudentComment.astro";
import RegistrationInfo from "@/components/RegistrationInfo.astro";
import FAQ from "@/components/FAQ.astro";
import OrganizersBrands from "@/components/OrganizerBrands.astro";
import homeData from "@/data/home.json";
import { markdownToPlainText } from "@/utils/markdown";

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: homeData.faq.items.map(item => ({
		"@type": "Question",
		name: item.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: markdownToPlainText(item.answer)
		}
	}))
};
---

<Layout additionalStructuredData={faqSchema}>
	<Hero />
	<BrandMarquee />
	<MasterClass />
	<MasterCarousel />
	<AboutSitconCamp />
	<StudentComment />
	<RegistrationInfo />
	<FAQ />
	<OrganizersBrands />
</Layout>

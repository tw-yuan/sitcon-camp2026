---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import SitconCampLogo from '../assets/sitcon-camp.svg';
import introVideo from '../assets/intro.mp4';
import classActivitiesImage from '../assets/group/class-activities.jpg';
import designImage from '../assets/group/design.jpg';
import developImage from '../assets/group/develop.jpg';
import editingGroupImage from '../assets/group/editing-group.jpg';
import fieldAffairsImage from '../assets/group/field-affairs.jpg';
import teamAssistantImage from '../assets/group/team-assistant.jpg';
import history2014Image from '../assets/history/2014.jpg';
import history2015Image from '../assets/history/2015.jpg';
import history2016Image from '../assets/history/2016.jpg';
import history2017Image from '../assets/history/2017.jpg';
import history2019Image from '../assets/history/2019.jpg';
import history2021Image from '../assets/history/2021.jpg';
import history2023Image from '../assets/history/2023.jpg';
import history2024Image from '../assets/history/2024.jpg';
import history2025Image from '../assets/history/2025.jpg';

const recruitTeams = [
	{
		name: '隊輔組',
		description: '陪伴學員、協助學習、帶動活動氣氛。',
		deadline: '4/18 23:59',
		link: 'https://forms.gle/YJsYyTB9XSLcWdBg8',
		image: teamAssistantImage,
	},
	{
		name: '編輯組',
		description: '經營社群、寫文案、剪輯影音、發想宣傳內容。',
		deadline: '4/25 23:59',
		link: 'https://forms.gle/7LCEaH2zD3V5vDZC6',
		image: editingGroupImage,
	},
	{
		name: '課程活動組',
		description: '規劃主線課程、活動內容與營期流程。',
		deadline: '4/14 23:59',
		link: 'https://forms.gle/TFUEkkvjR1po38B2A',
		image: classActivitiesImage,
	},
	{
		name: '設計組',
		description: '負責主視覺、網頁、社群出圖與整體視覺。',
		deadline: '招募中',
		link: 'https://forms.gle/ztny7QQ3vX6yvM4U8',
		image: designImage,
	},
	{
		name: '開發組',
		description: '開發 Camp 官網與營期間會用到的活動網站。',
		deadline: '4/24 截止',
		link: 'https://forms.gle/3AZ9MFu4nA1uCQheA',
		image: developImage,
	},
	{
		name: '庶務組',
		description: '負責學員與工作人員的吃住與現場後勤。',
		deadline: '4/18 截止',
		link: 'https://t.me/agong1021',
		image: fieldAffairsImage,
	},
];

const deadlineOrder = (deadline: string) => {
	const match = deadline.match(/(\d{1,2})\/(\d{1,2})/);
	if (!match) {
		return Number.POSITIVE_INFINITY;
	}

	const [, month, day] = match;
	return Number(month) * 100 + Number(day);
};

const sortedRecruitTeams = [...recruitTeams].sort(
	(a, b) => deadlineOrder(a.deadline) - deadlineOrder(b.deadline)
);

const faqItems = [
	{
		question: '沒有辦過活動，也可以加入嗎？',
		answer: '可以。很多組別都歡迎願意學習、願意一起做事的人加入，不需要一開始就很熟。',
	},
	{
		question: '不會寫程式，也能加入嗎？',
		answer: '可以。除了開發組，還有行政、編輯、設計、隊輔、庶務、課程活動等不同角色。',
	},
	{
		question: '工作人員一定要上營嗎？',
		answer: '不一定，每組需求不同。隊輔與部分開發、現場組別會需要上營，細節請看各組招募資訊。',
	},
	{
		question: '學員報名開始了嗎？',
		answer: '還沒。學員報名開始時間尚未公布，屆時會再公告相關資訊。',
	},
];

const groupPhotos = [
	{
		src: history2014Image,
		alt: 'SITCON Camp 2014 歷屆大合照',
	},
	{
		src: history2015Image,
		alt: 'SITCON Camp 2015 歷屆大合照',
	},
	{
		src: history2016Image,
		alt: 'SITCON Camp 2016 歷屆大合照',
	},
	{
		src: history2017Image,
		alt: 'SITCON Camp 2017 歷屆大合照',
	},
	{
		src: history2019Image,
		alt: 'SITCON Camp 2019 歷屆大合照',
	},
	{
		src: history2021Image,
		alt: 'SITCON Camp 2021 歷屆大合照',
	},
	{
		src: history2023Image,
		alt: 'SITCON Camp 2023 歷屆大合照',
	},
	{
		src: history2024Image,
		alt: 'SITCON Camp 2024 歷屆大合照',
	},
	{
		src: history2025Image,
		alt: 'SITCON Camp 2025 歷屆大合照',
	},
];

const staffMembers = [
	{
		name: 'Windless',
		role: '總召',
		avatar:
			'https://gravatar.com/avatar/5b168d8b83a4f506cf9be7b9b86b7ffc2b7a8dee29e5f6c82f9720764fc05f4d?s=200&d=identicon',
	},
	{
		name: 'Fearnot',
		role: '副召',
		avatar:
			'https://gravatar.com/avatar/4e2c4d83a0da00261fc8fe88cfaa70d8892fcb144feb4149eb926b6f7aef597d?s=200&d=identicon',
	},
	{
		name: 'Ya',
		role: '行政組 組長',
		avatar:
			'https://gravatar.com/avatar/3dc682683048afd1630ae4329b7269a2dc9fa301480a8abe6e974893eba6683d?s=200&d=identicon',
	},
	{
		name: 'Wolf Yuan',
		role: '隊輔組 組長',
		avatar:
			'https://gravatar.com/avatar/3d77e79456c983f048d74ea2739e8acbcc222d882bf294401209e00435c6b2d7?s=200&d=identicon',
	},
	{
		name: 'Mina',
		role: '編輯組 組長',
		avatar:
			'https://gravatar.com/avatar/dbfbb99d57882e065243ab549d00d63eabb2dfa8e5ba7d9e7abb1ed0daa2c3f4?s=200&d=identicon',
	},
	{
		name: 'Nathan',
		role: '課程活動組 組長',
		avatar:
			'https://gravatar.com/avatar/e087ca958a3115405b32e62072ff801b5dfcb4179607a1c56f20df88043e16ab?s=200&d=identicon',
	},
	{
		name: 'Yoru',
		role: '開發組 組長',
		avatar:
			'https://gravatar.com/avatar/cdf78bfb55f7be52400da72e2b780ffc62af848476b998f80bbf287c67b231a7?s=200&d=identicon',
	},
	{
		name: '康喔',
		role: '紀錄組 組長',
		avatar:
			'https://gravatar.com/avatar/08b25778f9a9ca3f2591b4e859be426dbd075608d763daf4fdd244d48eb26f13?s=200&d=identicon',
	},
	{
		name: '阿公',
		role: '庶務組 組長',
		avatar:
			'https://gravatar.com/avatar/196e64709935c454b821b5de526e48cf790dbd78a0606642405a35ae592e63d2?s=200&d=identicon',
	},
	{
		name: 'Lindy',
		role: '財務組 組長',
		avatar:
			'https://gravatar.com/avatar/6c6c3bed1c257ebdba662b12111724bc96ff804c41936045954acc6b60dc81b5?s=200&d=identicon',
	},
];

const vlog = {
	title: '2025 Vlog',
	url: 'https://www.youtube.com/watch?v=CansA62TYXY',
	thumbnail: 'https://img.youtube.com/vi/CansA62TYXY/maxresdefault.jpg',
};

const publicCalendarUrl =
	'https://calendar.google.com/calendar/embed?src=rf14d0k6cfstdnac3bigqv72ho%40group.calendar.google.com&ctz=Asia%2FTaipei';
const seoDescription =
	'SITCON Camp 2026 是由學生辦、給學生玩的資訊科技夏令營，將於 2026 年 7 月 8 日至 7 月 12 日在國立陽明交通大學舉辦。';
---

<Layout title="SITCON Camp 2026" description={seoDescription} image="/og-image.jpg">
	<div class="bg-paper text-ink">
		<header data-header class="site-header fixed inset-x-0 top-0 z-30 border-b border-line bg-paper/80 backdrop-blur-sm">
			<div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
				<a href="#top" class="inline-flex" aria-label="SITCON Camp" data-hero-item>
					<SitconCampLogo class="h-7 w-auto invert md:h-8" aria-hidden="true" />
				</a>
				<nav class="hidden gap-6 text-sm md:flex">
					<a href="#about" class="hover:text-rust">關於</a>
					<a href="#recruit" class="hover:text-rust">加入工作人員</a>
					<a href="#timeline" class="hover:text-rust">時程</a>
					<a href="#team" class="hover:text-rust">工作人員</a>
					<a href="#faq" class="hover:text-rust">FAQ</a>
				</nav>
				<a
					href="https://i.sitcon.org/camp-recruit"
					target="_blank"
					rel="noreferrer"
					class="soft-button inline-flex items-center bg-rust px-4 py-2 text-sm font-medium text-cream hover:bg-rust-strong"
				>
					立即跳坑
				</a>
			</div>
		</header>

		<main id="top" class="relative z-10">
			<section data-hero-section class="relative overflow-hidden border-b border-line bg-sand/15 text-cream">
				<video
					data-hero-video
					class="absolute inset-0 h-full w-full object-cover object-[62%_center] md:object-center"
					autoplay
					muted
					loop
					playsinline
					aria-hidden="true"
				>
					<source src={introVideo} type="video/mp4" />
				</video>
				<div class="absolute inset-0 bg-ink/56"></div>
				<div class="relative z-10 mx-auto flex min-h-screen max-w-6xl items-center px-6 py-20 md:py-28">
					<div class="max-w-4xl">
						<p data-hero-item class="mb-4 text-sm tracking-[0.2em] text-cream/80">第 10 屆</p>
						<h1 data-hero-item class="max-w-4xl text-5xl font-semibold leading-tight md:text-7xl lg:text-[5.5rem]">
							SITCON Camp 2026
						</h1>
						<p data-hero-item class="mt-6 max-w-4xl text-lg leading-8 text-cream/90 md:text-xl lg:max-w-5xl">
							今夏，我們回來了。學生辦的、給學生玩的資訊科技夏令營，工作人員招募中。
						</p>
						<div data-hero-item class="mt-8 flex flex-wrap gap-3 text-sm text-cream/90">
							<div class="soft-chip border border-cream/35 bg-paper/18 px-3 py-2 shadow-sm backdrop-blur-md">7/8 - 7/12</div>
							<div class="soft-chip border border-cream/35 bg-paper/18 px-3 py-2 shadow-sm backdrop-blur-md">國立陽明交通大學</div>
							<div class="soft-chip border border-cream/35 bg-paper/18 px-3 py-2 shadow-sm backdrop-blur-md">五天四夜</div>
						</div>
						<div data-hero-item class="mt-10 flex flex-wrap gap-4">
							<a
								href="https://i.sitcon.org/camp-recruit"
								target="_blank"
								rel="noreferrer"
								class="soft-button inline-flex items-center bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
							>
								工人跳坑表單
							</a>
							<a href="#about" class="soft-button inline-flex items-center border border-cream/45 bg-paper/14 px-5 py-3 text-cream backdrop-blur-md hover:bg-paper/22">
								了解更多
							</a>
						</div>
					</div>
				</div>
			</section>

			<section class="border-b border-line bg-cream/50">
				<div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-5 md:flex-row md:items-center md:justify-between">
					<div>
						<p class="text-sm tracking-[0.2em] text-rust">PUBLIC CALENDAR</p>
						<p class="mt-1 text-sm leading-7 text-ink/90">
							追蹤 SITCON Camp 的公開時程與重要節點。
						</p>
					</div>
					<a
						href={publicCalendarUrl}
						target="_blank"
						rel="noreferrer"
						class="soft-button inline-flex items-center bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
					>
						開啟 Google Calendar
					</a>
				</div>
			</section>

			<section id="about" class="border-b border-line">
				<div data-reveal class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-2">
					<div>
						<p class="mb-3 text-sm tracking-[0.2em] text-rust">ABOUT</p>
						<h2 class="text-3xl font-semibold">什麼是 SITCON Camp？</h2>
					</div>
					<div class="space-y-5 text-base leading-8 text-ink/90">
						<p>
							SITCON Camp 是一個由學生辦、給學生玩的資訊科技夏令營。不是培訓班，也不是補習班，而是一群熱愛資訊的人聚在一起，一起學、一起做、一起搞事的地方。
						</p>
						<p>
							2026 年是第 10 屆。這次落腳國立陽明交通大學，從 7 月 8 日到 7 月 12 日，五天四夜。
						</p>
						<p>
							課程主題仍在籌備中，工作人員招募已經開始。想一起把這屆 Camp 做出來的人，現在就可以加入。
						</p>
					</div>
				</div>
			</section>

			<section id="recruit" class="border-b border-line bg-cream/60">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<div data-reveal class="grid gap-8 md:grid-cols-[1fr_2fr] md:items-start">
						<div>
							<p class="mb-3 text-sm tracking-[0.2em] text-rust">RECRUIT</p>
							<h2 class="text-3xl font-semibold">一起把這屆 Camp 做出來</h2>
						</div>
						<div class="space-y-5 text-base leading-8 text-ink/90">
							<p>
								每個活動的成功，皆仰賴在幕後默默付出的工作人員。如果你也想參與活動的籌備，和一群實力堅強且有想法的人一起完成這件事，歡迎依照自己的專長與興趣加入我們。
							</p>
							<p>
								各組招募資訊、截止日期與報名入口已整理在下面；完整職缺說明可以直接看招募文件。
							</p>
							<div class="flex flex-wrap gap-4 pt-2">
								<a
									href="https://i.sitcon.org/camp-recruit"
									target="_blank"
									rel="noreferrer"
									class="soft-button inline-flex items-center bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
								>
									立即跳坑
								</a>
							</div>
						</div>
					</div>

					<div data-stagger class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
						{
							sortedRecruitTeams.map((team) => (
								<article data-stagger-item class="soft-card overflow-hidden border border-line bg-paper shadow-[0_20px_40px_color-mix(in_srgb,var(--color-ink)_8%,transparent)]">
									<Image
										src={team.image}
										alt={team.name}
										class="h-44 w-full object-cover"
										loading="lazy"
									/>
									<div class="p-5">
										<div class="flex items-start justify-between gap-4">
											<h3 class="text-xl font-semibold">{team.name}</h3>
											<span class="text-sm text-rust">{team.deadline}</span>
										</div>
										<p class="mt-4 text-sm leading-7 text-ink/90">{team.description}</p>
										<a
											href={team.link}
											target="_blank"
											rel="noreferrer"
											class="soft-button mt-6 inline-block border border-line px-4 py-2 text-sm hover:bg-cream"
										>
											立即跳坑
										</a>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="timeline" class="border-b border-line">
				<div data-reveal class="mx-auto max-w-6xl px-6 py-16">
					<p class="mb-3 text-sm tracking-[0.2em] text-rust">TIMELINE</p>
					<h2 class="text-3xl font-semibold">重要時程</h2>
					<div class="soft-frame mt-10 grid gap-px overflow-hidden border border-line bg-line md:grid-cols-2">
						<div class="soft-card bg-cream p-5 shadow-sm">
							<p class="text-sm">2026 / 04 / 01</p>
							<p class="mt-2 text-lg font-medium">一切從這裡開始</p>
						</div>
						<div class="soft-card bg-cream p-5 shadow-sm">
							<p class="text-sm">2026 / 04 / 01</p>
							<p class="mt-2 text-lg font-medium">工人跳坑開始</p>
						</div>
						<div class="soft-card bg-cream p-5 shadow-sm">
							<p class="text-sm">TBD</p>
							<p class="mt-2 text-lg font-medium">工人跳坑截止</p>
						</div>
						<div class="soft-card bg-cream p-5 shadow-sm">
							<p class="text-sm">TBD</p>
							<p class="mt-2 text-lg font-medium">線上籌備開跑</p>
						</div>
						<div class="soft-card bg-cream p-5 shadow-sm">
							<p class="text-sm">TBD</p>
							<p class="mt-2 text-lg font-medium">工人相見歡</p>
						</div>
						<div class="soft-card bg-cream p-5 shadow-sm">
							<p class="text-sm">TBD</p>
							<p class="mt-2 text-lg font-medium">學員報名開始</p>
						</div>
						<div class="soft-card bg-cream p-5 shadow-sm md:col-span-2">
							<p class="text-sm">2026 / 07 / 08 - 07 / 12</p>
							<p class="mt-2 text-lg font-medium">出發</p>
						</div>
					</div>
				</div>
			</section>

			<section id="team" class="border-b border-line bg-sand/10">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<p class="mb-3 text-sm tracking-[0.2em] text-rust">TEAM</p>
					<h2 class="text-3xl font-semibold">工作人員</h2>
					<p class="mt-4 max-w-2xl text-base leading-8 text-ink/90">
						因為有這群人在背後搞事，才有今年的五天四夜。
					</p>
					<div data-stagger class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
						{
							staffMembers.map((member) => (
								<article data-stagger-item class="soft-card border border-line bg-paper p-5 shadow-[0_16px_32px_color-mix(in_srgb,var(--color-ink)_8%,transparent)]">
									<div class="flex items-center gap-4">
										{member.avatar && (
											<Image
												src={member.avatar}
												alt={member.name}
												width={200}
												height={200}
												class="soft-avatar h-16 w-16 shrink-0 border border-line object-cover"
												loading="lazy"
											/>
										)}
										<div class="min-w-0">
											<p class="text-xl font-semibold">{member.name}</p>
											<p class="mt-1 text-sm leading-7 text-ink/80">{member.role}</p>
										</div>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="border-b border-line">
				<div class="mx-auto max-w-6xl px-6 py-16">
					<div data-reveal class="soft-frame grid gap-8 overflow-hidden border border-line bg-cream shadow-[0_28px_60px_color-mix(in_srgb,var(--color-ink)_10%,transparent)] md:grid-cols-[1fr_1.4fr]">
						<div class="flex flex-col justify-between p-8 md:p-10">
							<div>
								<p class="mb-3 text-sm tracking-[0.2em] text-rust">VLOG</p>
								<h2 class="text-3xl font-semibold">先看看去年的 Camp</h2>
								<p class="mt-5 max-w-lg text-base leading-8 text-ink/90">
									如果你想知道 SITCON Camp 的五天四夜到底長什麼樣子，這支影片會比任何一段介紹都更直接。
								</p>
								<p class="mt-4 max-w-lg text-base leading-8 text-ink/90">
									課程、黑客松、社群交流，還有一群把事情做出來的人，都在這裡。
								</p>
							</div>
							<div class="mt-8 flex flex-wrap gap-4">
								<a
									href={vlog.url}
									target="_blank"
									rel="noreferrer"
									class="soft-button bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
								>
									觀看 2025 Vlog
								</a>
							</div>
						</div>
						<a
							href={vlog.url}
							target="_blank"
							rel="noreferrer"
							class="group relative block min-h-[320px] overflow-hidden border-t border-line md:min-h-[420px] md:border-t-0 md:border-l"
						>
							<Image
								src={vlog.thumbnail}
								alt={vlog.title}
								width={1280}
								height={720}
